    gap: 1rem;
    margin: 1.2rem 0;
  }
  .pricing-card {
    padding: 1.2rem;
    border: 1px solid var(--rule);
    background: var(--paper-soft);
  }
  .pricing-card h3 {
    margin: 0 0 0.4rem;
    font-size: var(--fs-h3);
  }
  .pricing-card__when {
    font-size: var(--fs-small);
    color: var(--ink-faint);
    font-style: italic;
    margin-bottom: 0.6rem;
  }
  .pricing-card a {
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    color: var(--lavender-dim);
