---
import PageLayout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { pickTitle } from '~/lib/collection-helpers';
import { buildBacklinks } from '~/lib/backlinks';

const [workflows, documents, clauses, terms, roles, cases] = await Promise.all([
  getCollection('workflows'),
  getCollection('documents'),
  getCollection('clauses'),
  getCollection('terms'),
  getCollection('roles'),
  getCollection('cases'),
]);

// Pillar split for workflows
const clientWorkflows = workflows.filter((w) => w.data.pillar === 'client-engagement');
const peopleWorkflows = workflows.filter((w) => w.data.pillar === 'people');

// Pillar split for documents (by composedOf tags or by workflow binding)
const docIdsInClient = new Set(
  clientWorkflows.flatMap((w) => (w.data.steps ?? []).flatMap((s: any) => s.uses ?? [])),
);
const docIdsInPeople = new Set(
  peopleWorkflows.flatMap((w) => (w.data.steps ?? []).flatMap((s: any) => s.uses ?? [])),
);
const clientDocs = documents.filter((d) => docIdsInClient.has(d.data.id));
const peopleDocs = documents.filter((d) => docIdsInPeople.has(d.data.id));

// Top cases (most recently touched, or by case count of workflows)
const topCases = cases.slice(0, 5);

// Counts for the explore strip
const counts = {
  workflows: workflows.length,
  documents: documents.length,
  clauses: new Set(clauses.map((c) => c.data.baseId || c.data.id)).size,
  terms: terms.length,
  roles: roles.length,
  cases: cases.length,
};

// Top-5 most-referenced clauses (real wiki superpower)
const backlinks = await buildBacklinks();
const clauseUsage = new Map<string, number>();
const clauseTitle = new Map<string, string>();
for (const c of clauses) {
  const base = c.data.baseId || c.data.id;
  if (!clauseTitle.has(base)) clauseTitle.set(base, pickTitle(c.data.title));
  const refs = backlinks.get(`clauses/${base}`) || [];
  clauseUsage.set(base, Math.max(clauseUsage.get(base) ?? 0, refs.length));
}
const topClauses = [...clauseUsage.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5)
  .filter(([, n]) => n > 0);
---

<PageLayout title="Drafters" crumbSegments={[]}>
  <h1 class="display">Drafters<span class="display-cursor" aria-hidden="true"></span></h1>
  <p class="lead">
    Робоча вікі для ІТ-сервісних компаній. Бі-лінгвальна. Модульна.
    Два піллари — клієнтський engagement та people/hiring — сходяться
    в кейсах, які показують, як реальна робота рухається між ними.
  </p>

  <div class="hero-search">
    <button class="hero-search__input" data-open-palette aria-label="Шукати по вікі">
      <span class="hero-search__placeholder">Пошук по всьому тексту…</span>
      <kbd>/</kbd>
    </button>
    <p class="hero-search__hint">
      Натисни <kbd>/</kbd> або <kbd>⌘K</kbd> з будь-якої сторінки.
    </p>
  </div>

  <nav class="explore-strip" aria-label="Колекції">
    <a href="/workflows"><span>Процеси</span><em>{counts.workflows}</em></a>
    <a href="/documents"><span>Документи</span><em>{counts.documents}</em></a>
    <a href="/contracts"><span>Контракти</span><em>5</em></a>
    <a href="/clauses"><span>Пункти</span><em>{counts.clauses}</em></a>
    <a href="/terms"><span>Терміни</span><em>{counts.terms}</em></a>
    <a href="/roles"><span>Ролі</span><em>{counts.roles}</em></a>
    <a href="/cases"><span>Кейси</span><em>{counts.cases}</em></a>
  </nav>

  <div class="pillars">
    <section class="pillar">
      <header>
        <h2 class="pillar__title">Client engagement</h2>
        <p class="pillar__sub">Як ми знайомимось, підписуємось, працюємо з клієнтом.</p>
      </header>
      <ul class="pillar__list">
        {clientWorkflows.map((w) => (
          <li>
            <a href={`/workflows/${w.data.id}`}>{pickTitle(w.data.title)}</a>
          </li>
        ))}
      </ul>
      {clientDocs.length > 0 && (
        <p class="pillar__docs">
          Ключові документи:{' '}
          {clientDocs.slice(0, 4).map((d, i) => (
            <>
              {i > 0 && ', '}
              <a href={`/documents/${d.data.id}`}>{pickTitle(d.data.title)}</a>
            </>
          ))}
        </p>
      )}
    </section>

    <section class="pillar">
      <header>
        <h2 class="pillar__title">People / hiring</h2>
        <p class="pillar__sub">Як ми беремо субконтракторів і команди.</p>
      </header>
      <ul class="pillar__list">
        {peopleWorkflows.map((w) => (
          <li>
            <a href={`/workflows/${w.data.id}`}>{pickTitle(w.data.title)}</a>
          </li>
        ))}
      </ul>
      {peopleDocs.length > 0 && (
        <p class="pillar__docs">
          Ключові документи:{' '}
          {peopleDocs.slice(0, 4).map((d, i) => (
            <>
              {i > 0 && ', '}
              <a href={`/documents/${d.data.id}`}>{pickTitle(d.data.title)}</a>
            </>
          ))}
        </p>
      )}
    </section>
  </div>

  {topCases.length > 0 && (
    <section class="featured">
      <p class="divider">Сценарії</p>
      <ul class="featured__list">
        {topCases.map((c: any) => (
          <li>
            <a href={`/cases/${c.data.id}`}>{pickTitle(c.data.title)}</a>
            <span class="pill">{(c.data.workflows ?? []).length} процеси</span>
          </li>
        ))}
      </ul>
      <p class="featured__more">
        <a href="/cases">Усі кейси →</a>
      </p>
    </section>
  )}

  {topClauses.length > 0 && (
    <section class="featured">
      <p class="divider">Найбільш посилані пункти</p>
      <ul class="featured__list">
        {topClauses.map(([base, n]) => (
          <li>
            <a href={`/clauses/${base}`}>{clauseTitle.get(base)}</a>
            <span class="pill">{n}×</span>
          </li>
        ))}
      </ul>
      <p class="featured__more">
        <a href="/clauses">Усі пункти →</a>
      </p>
    </section>
  )}
</PageLayout>

<style>
  .hero-search {
    margin: 2.4rem 0 2.4rem;
  }
  .hero-search__input {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: var(--paper);
    border: 1px solid var(--ink);
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--ink);
    cursor: pointer;
    text-align: left;
    box-shadow: 4px 4px 0 0 var(--lavender-wash);
    transition: box-shadow var(--t-base), background var(--t-base);
  }
  .hero-search__input:hover,
  .hero-search__input:focus {
    background: var(--lavender-wash);
    box-shadow: 6px 6px 0 0 var(--lavender);
    outline: none;
  }
  .hero-search__placeholder {
    color: var(--ink-muted);
    font-style: italic;
  }
  .hero-search__input kbd {
    font-family: var(--font-sans);
    font-size: var(--fs-meta);
    padding: 0.15em 0.5em;
    border: 1px solid var(--rule);
    color: var(--ink-muted);
  }
  .hero-search__hint {
    margin: 0.6rem 0 0;
    font-size: var(--fs-meta);
    color: var(--ink-faint);
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
  }
  .hero-search__hint kbd {
    padding: 0.05em 0.4em;
    border: 1px solid var(--rule);
  }

  .explore-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 3rem;
  }
  .explore-strip a {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--rule);
    color: var(--ink);
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: var(--fs-meta);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    transition: background var(--t-base), border-color var(--t-base);
  }
  .explore-strip a:hover {
    background: var(--lavender-wash);
    border-color: var(--ink);
  }
  .explore-strip em {
    font-style: normal;
    color: var(--ink-faint);
    font-weight: var(--fw-regular);
  }

  .pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    margin: 0 0 3rem;
  }
  @media (max-width: 720px) {
    .pillars {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
  .pillar header {
    margin-bottom: 1rem;
  }
  .pillar__title {
    font-size: 1.35rem;
    font-weight: var(--fw-regular);
    margin: 0 0 0.3rem;
  }
  .pillar__sub {
    margin: 0;
    color: var(--ink-muted);
    font-size: var(--fs-small);
    font-style: italic;
  }
  .pillar__list {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .pillar__list a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color var(--t-base), border-color var(--t-base);
  }
  .pillar__list a:hover {
    color: var(--lavender-dim);
    border-bottom-color: var(--lavender-dim);
  }
  .pillar__docs {
    margin: 0.4rem 0 0;
    font-size: var(--fs-small);
    color: var(--ink-muted);
    line-height: 1.55;
  }

  .featured {
    margin: 2.5rem 0 0;
  }
  .featured__list {
    list-style: none;
    padding: 0;
    margin: 0.6rem 0 0.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .featured__list li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.3rem 0;
    border-bottom: 1px dashed var(--rule);
  }
  .featured__list a {
    color: var(--ink);
    text-decoration: none;
  }
  .featured__list a:hover {
    color: var(--lavender-dim);
  }
  .featured__more {
    margin: 0.8rem 0 0;
    font-size: var(--fs-small);
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-muted);
  }
  .featured__more a {
    color: var(--ink-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .featured__more a:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }
</style>
