---
import PageLayout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { listClauseBases } from '~/lib/clause-variants';


const safeGet = async (name: any) => {
  try { return await getCollection(name); } catch { return []; }
};

const workflows = await getCollection('workflows');
const documents = await getCollection('documents');
const contracts = await safeGet('contracts');
const bases = await listClauseBases();
const terms = await getCollection('terms');
const roles = await getCollection('roles');
const cases = await safeGet('cases');
const cast = await safeGet('cast');

function pickTitle(title: any): string {
  if (typeof title === 'string') return title;
  return title?.uk || title?.en || title?.de || '';
}

// Deduplicate contracts by baseId (show one entry per template, not per language variant)
const contractBases = new Map<string, any>();
for (const c of contracts) {
  const base = c.data.baseId || c.data.id;
  if (!contractBases.has(base)) contractBases.set(base, c);
}

// Split workflows by pillar
const peopleWorkflows = workflows.filter((w) => w.data.pillar === 'people');
const clientWorkflows = workflows.filter((w) => w.data.pillar === 'client-engagement');
const otherWorkflows = workflows.filter((w) => !['people', 'client-engagement'].includes(w.data.pillar));
---

<PageLayout title="Drafters" crumbSegments={[]}>
  <h1 class="display">Drafters<span class="display-cursor" aria-hidden="true"></span></h1>

  <div class="about-section">
    <p class="lead dropcap">
      A modular contract wiki for IT services companies. Every agreement
      is assembled from reusable clauses. Every clause links back to the
      contracts, cases, and workflows that use it. Change a clause once —
      the update propagates everywhere.
    </p>

    <h2>How it works</h2>
    <p>
      <strong>Clauses</strong> are the building blocks — small, reusable legal fragments
      (IP assignment, payment terms, termination, liability caps). Each clause
      exists as its own wiki page with commentary explaining why it's written
      the way it is.
    </p>
    <p>
      <strong>Contracts</strong> are assembled from clauses. An MSA, a T&M agreement, an NDA —
      each one composes the clauses it needs, in order. The same liability clause
      that appears in your MSA also appears in your subcontract, with one source
      of truth.
    </p>
    <p>
      <strong>Cases</strong> tell the stories of how these contracts were tested in practice.
      Real scenarios (anonymized) where a payment dispute, an IP assignment, or
      a non-solicit question forced us to read the paper we wrote. Each case
      links to the clauses and contracts involved.
    </p>
    <p>
      <strong>Cast</strong> members are the recurring clients and people who appear across
      cases — each with their own personality, jurisdiction, and negotiating
      style that shapes how contracts evolve over time.
    </p>
  </div>

  <p class="divider">Contract Templates</p>
  <ul class="content-list">
    {[...contractBases.values()].map((c) => (
      <li>
        <a href={`/contracts/${c.data.baseId || c.data.id}`}>{pickTitle(c.data.title)}</a>
        <span class="pill">{c.data.lang}</span>
      </li>
    ))}
  </ul>

  {clientWorkflows.length > 0 && (
    <>
      <p class="divider">Client Engagement</p>
      <ul class="content-list">
        {clientWorkflows.map((w) => (
          <li>
            <a href={`/workflows/${w.data.id}`}>{pickTitle(w.data.title)}</a>
            <span class="pill pill--accent">{w.data.pillar}</span>
          </li>
        ))}
      </ul>
    </>
  )}

  {peopleWorkflows.length > 0 && (
    <>
      <p class="divider">People / Hiring</p>
      <ul class="content-list">
        {peopleWorkflows.map((w) => (
          <li>
            <a href={`/workflows/${w.data.id}`}>{pickTitle(w.data.title)}</a>
            <span class="pill pill--active">{w.data.pillar}</span>
          </li>
        ))}
      </ul>
    </>
  )}

  {otherWorkflows.length > 0 && (
    <>
      <p class="divider">Other Processes</p>
      <ul class="content-list">
        {otherWorkflows.map((w) => (
          <li>
            <a href={`/workflows/${w.data.id}`}>{pickTitle(w.data.title)}</a>
            <span class="pill">{w.data.pillar}</span>
          </li>
        ))}
      </ul>
    </>
  )}

  {cases.length > 0 && (
    <>
      <p class="divider">Cases</p>
      <ul class="content-list">
        {cases.map((c: any) => (
          <li>
            <a href={`/cases/${c.data.id}`}>{pickTitle(c.data.title)}</a>
            <span class="pill">{(c.data.workflows ?? []).length} workflows</span>
          </li>
        ))}
      </ul>
    </>
  )}

  <p class="divider">Documents</p>
  <ul class="content-list">
    {documents.map((d) => (
      <li>
        <a href={`/documents/${d.data.id}`}>{pickTitle(d.data.title)}</a>
        <span class="pill">{d.data.type}</span>
      </li>
    ))}
  </ul>

  <p class="divider">Reusable Clauses</p>
  <ul class="content-list">
    {bases.map((b) => (
      <li>
        <a href={`/clauses/${b.baseId}`}>{pickTitle(b.preferred.data.title)}</a>
        <span class="pill">{b.languages.join(' · ')}</span>
      </li>
    ))}
  </ul>

  <p class="divider">Glossary</p>
  <ul class="content-list">
    {terms.map((t) => (
      <li>
        <a href={`/terms/${t.data.id}`}>{pickTitle(t.data.title)}</a>
      </li>
    ))}
  </ul>

  <p class="divider">Roles</p>
  <ul class="content-list">
    {roles.map((r) => (
      <li>
        <a href={`/roles/${r.data.id}`}>{pickTitle(r.data.title)}</a>
      </li>
    ))}
  </ul>

  <p class="divider">About this project</p>
  <p>
    Drafters is a modular, bilingual contract wiki for IT services companies.
    Every workflow references documents, every document is composed of reusable
    clauses, and every term has a tooltip. Everything is static files — MDX
    source, built with Astro, deployed from GitHub to Vercel. Export to Word
    is available for contracts and clauses.
  </p>
</PageLayout>

<style>
  .about-section {
    max-width: var(--measure);
    margin-bottom: 2rem;
  }
  .about-section h2 {
    margin-top: 2rem;
  }
  .about-section p {
    margin-bottom: 0.8rem;
  }
</style>
