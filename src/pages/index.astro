---
import PageLayout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { listClauseBases } from '~/lib/clause-variants';

function pickTitle(title: any, preferred: 'en' | 'uk' = 'en'): string {
  if (typeof title === 'string') return title;
  return title?.[preferred] || title?.en || title?.uk || title?.de || '';
}

const contracts = await getCollection('contracts');
const bases = await listClauseBases();

// Deduplicate contracts by baseId
const contractBases = new Map<string, any>();
for (const c of contracts) {
  const base = c.data.baseId || c.data.id;
  if (!contractBases.has(base)) contractBases.set(base, c);
}
const contractList = [...contractBases.values()].sort((a, b) =>
  pickTitle(a.data.title).localeCompare(pickTitle(b.data.title))
);
---

<PageLayout title="Drafters" crumbSegments={[]} lang="en">
  <h1 class="display">Drafters</h1>

  <p class="lead">
    A composable contract reference library with three views over every
    document — signable, annotated, briefed. Built on markdown files,
    wiki-style cross-refs, and five annotation voices.
  </p>

  <section class="home-section">
    <h2>Contracts</h2>
    <ul class="home-list">
      {contractList.map((c) => (
        <li>
          <a href={`/contracts/${c.data.baseId || c.data.id}`}>
            {pickTitle(c.data.title)}
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="home-section">
    <h2>Clauses <span class="home-count">{bases.length}</span></h2>
    <p>
      <a href="/clauses">Browse the clause library →</a>
    </p>
  </section>

  <style>
    .home-section {
      margin-top: 3rem;
    }
    .home-section h2 {
      font-family: var(--font-sans);
      font-size: 1.05rem;
      font-weight: var(--fw-bold);
      margin-bottom: 0.8rem;
      border-top: 1px solid var(--rule);
      padding-top: 1.2rem;
    }
    .home-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .home-list li {
      padding: 0.4rem 0;
      border-bottom: 1px dotted var(--rule);
    }
    .home-list a {
      font-family: var(--font-serif);
      font-size: 1.05rem;
      color: var(--ink);
      text-decoration: none;
    }
    .home-list a:hover {
      color: var(--lavender-dim);
    }
    .home-count {
      font-family: var(--font-sans);
      font-weight: var(--fw-regular);
      color: var(--ink-faint);
      margin-left: 0.3rem;
    }
  </style>
</PageLayout>
