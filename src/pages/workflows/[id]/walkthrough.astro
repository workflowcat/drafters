---
/**
 * Walkthrough mode — one step at a time, full-screen, keyboard-driven.
 * This is the specific Drafters UX move: workflows can be "read" (the
 * normal detail page) or "walked through" (this page, which is
 * essentially a slide deck of steps).
 */
import { getCollection, getEntry, render } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';

export async function getStaticPaths() {
  const workflows = await getCollection('workflows');
  return workflows.map((w) => ({ params: { id: w.data.id }, props: { entry: w } }));
}

const { entry } = Astro.props as { entry: any };

const title =
  typeof entry.data.title === 'string'
    ? entry.data.title
    : entry.data.title.uk || entry.data.title.en || entry.data.id;

function pickTitle(t: any): string {
  if (typeof t === 'string') return t;
  return t?.uk || t?.en || t?.de || '';
}

const steps = entry.data.steps ?? [];
// Hydrate each step's role + documents
const stepCards: Array<{
  index: number;
  title: string;
  roleTitle: string | null;
  roleRoute: string | null;
  uses: Array<{ type: string; title: string; href: string }>;
}> = [];

for (let i = 0; i < steps.length; i++) {
  const step = steps[i];
  const stepTitle = pickTitle(step.title) || `Крок ${i + 1}`;
  let roleTitle: string | null = null;
  let roleRoute: string | null = null;
  if (step.role) {
    const role = await getEntry('roles', step.role).catch(() => null);
    if (role) {
      roleTitle = pickTitle(role.data.title);
      roleRoute = `/roles/${role.data.id}`;
    }
  }
  const uses: Array<{ type: string; title: string; href: string }> = [];
  for (const useId of step.uses ?? []) {
    const doc = await getEntry('documents', useId).catch(() => null);
    if (doc) {
      uses.push({
        type: 'document',
        title: pickTitle(doc.data.title),
        href: `/documents/${doc.data.id}`,
      });
      continue;
    }
    const clause = await getEntry('clauses', useId).catch(() => null);
    if (clause) {
      uses.push({
        type: 'clause',
        title: pickTitle(clause.data.title),
        href: `/clauses/${clause.data.id}`,
      });
    }
  }
  stepCards.push({
    index: i + 1,
    title: stepTitle,
    roleTitle,
    roleRoute,
    uses,
  });
}
---

<PageLayout
  title={`${title} — walkthrough`}
  crumbSegments={['workflows', entry.data.id, 'walkthrough']}
>
  <div class="walkthrough" data-walkthrough data-total={stepCards.length}>
    <header class="walkthrough__header">
      <p class="walkthrough__label">Walkthrough · {title}</p>
      <div class="walkthrough__progress">
        {stepCards.map((s) => (
          <span class="walkthrough__dot" data-step-dot={s.index}></span>
        ))}
      </div>
      <a class="btn btn--ghost" href={`/workflows/${entry.data.id}`}>← назад у режим читання</a>
    </header>

    <div class="walkthrough__stage" data-walkthrough-stage>
      {stepCards.map((s, i) => (
        <section class="walkthrough__step" data-step-index={s.index} aria-hidden={i !== 0}>
          <p class="walkthrough__step-counter">
            {String(s.index).padStart(2, '0')} / {String(stepCards.length).padStart(2, '0')}
          </p>
          <h1 class="walkthrough__step-title">{s.title}</h1>
          {s.roleTitle && s.roleRoute && (
            <p class="walkthrough__step-role">
              <span class="label">Роль:</span>{' '}
              <a href={s.roleRoute}>{s.roleTitle}</a>
            </p>
          )}
          {s.uses.length > 0 && (
            <div class="walkthrough__step-docs">
              <p class="label">Використовує:</p>
              <ul>
                {s.uses.map((u) => (
                  <li>
                    <a href={u.href}>{u.title}</a>
                    <span class="pill">{u.type}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </section>
      ))}
    </div>

    <footer class="walkthrough__controls">
      <button class="btn btn--ghost" data-walkthrough-prev>
        ← попередній
      </button>
      <span class="walkthrough__hint">
        <kbd>←</kbd> <kbd>→</kbd> або <kbd>j</kbd> <kbd>k</kbd>
      </span>
      <button class="btn btn--secondary" data-walkthrough-next>
        наступний →
      </button>
    </footer>
  </div>
</PageLayout>

<style>
  .walkthrough {
    max-width: 52rem;
    margin: 0 auto;
    padding: 1rem 0;
    min-height: calc(100vh - 10rem);
    display: flex;
    flex-direction: column;
  }
  .walkthrough__header {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1rem;
    margin-bottom: 3rem;
  }
  .walkthrough__label {
    font-family: var(--font-sans);
    font-size: var(--fs-meta);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-faint);
    margin: 0;
  }
  .walkthrough__progress {
    display: flex;
    gap: 0.6rem;
    flex: 1;
    justify-content: center;
  }
  .walkthrough__dot {
    width: 10px;
    height: 10px;
    border: 1px solid var(--ink);
    background: transparent;
    transition: background var(--t-base);
  }
  .walkthrough__dot.is-active {
    background: var(--lavender);
  }
  .walkthrough__dot.is-done {
    background: var(--ink);
  }
  .walkthrough__stage {
    flex: 1;
    position: relative;
    min-height: 24rem;
  }
  .walkthrough__step {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--t-slow);
  }
  .walkthrough__step[aria-hidden='false'] {
    opacity: 1;
    pointer-events: auto;
  }
  .walkthrough__step-counter {
    font-family: var(--font-sans);
    font-size: var(--fs-meta);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--lavender-dim);
    margin: 0 0 1rem;
  }
  .walkthrough__step-title {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 4vw + 1rem, 4.5rem);
    font-weight: var(--fw-light);
    line-height: var(--lh-tight);
    letter-spacing: -0.02em;
    margin: 0 0 2rem;
  }
  .walkthrough__step-role {
    font-family: var(--font-serif);
    font-size: var(--fs-lead);
    color: var(--ink-muted);
    margin: 0 0 2rem;
  }
  .walkthrough__step-docs {
    background: var(--paper-soft);
    border-left: 2px solid var(--lavender);
    padding: 1.4rem 1.6rem;
    margin-top: 2rem;
  }
  .walkthrough__step-docs .label {
    color: var(--ink-faint);
    margin: 0 0 0.6rem;
  }
  .walkthrough__step-docs ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .walkthrough__step-docs li {
    padding: 0.6rem 0;
    border-bottom: 1px dashed var(--rule);
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .walkthrough__step-docs li:last-child { border-bottom: 0; }
  .walkthrough__controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
    margin-top: 3rem;
  }
  .walkthrough__hint {
    font-family: var(--font-sans);
    font-size: var(--fs-meta);
    color: var(--ink-faint);
  }
</style>

<script>
  function setupWalkthrough() {
    const root = document.querySelector<HTMLElement>('[data-walkthrough]');
    if (!root) return;
    const total = parseInt(root.dataset.total || '0', 10);
    const steps = root.querySelectorAll<HTMLElement>('[data-step-index]');
    const dots = root.querySelectorAll<HTMLElement>('[data-step-dot]');
    const prev = root.querySelector<HTMLButtonElement>('[data-walkthrough-prev]');
    const next = root.querySelector<HTMLButtonElement>('[data-walkthrough-next]');
    let current = 1;

    function render() {
      steps.forEach((s) => {
        const idx = parseInt(s.dataset.stepIndex || '0', 10);
        s.setAttribute('aria-hidden', String(idx !== current));
      });
      dots.forEach((d) => {
        const idx = parseInt(d.dataset.stepDot || '0', 10);
        d.classList.toggle('is-active', idx === current);
        d.classList.toggle('is-done', idx < current);
      });
      if (prev) prev.disabled = current === 1;
      if (next) next.textContent = current === total ? 'завершити ✓' : 'наступний →';
    }

    prev?.addEventListener('click', () => {
      if (current > 1) {
        current--;
        render();
      }
    });
    next?.addEventListener('click', () => {
      if (current < total) {
        current++;
        render();
      } else {
        // Done — save completion
        const id = location.pathname.split('/').filter(Boolean)[1];
        try {
          localStorage.setItem(`drafters:walkthrough:${id}`, new Date().toISOString());
        } catch {}
        history.back();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (['INPUT', 'TEXTAREA'].includes((e.target as HTMLElement)?.tagName)) return;
      if (e.key === 'ArrowRight' || e.key === 'j') {
        e.preventDefault();
        next?.click();
      } else if (e.key === 'ArrowLeft' || e.key === 'k') {
        e.preventDefault();
        prev?.click();
      }
    });

    render();
  }
  setupWalkthrough();
  document.addEventListener('astro:page-load', setupWalkthrough);
</script>
