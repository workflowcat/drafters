---
import { getCollection } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import { pickTitle } from '~/lib/collection-helpers';

const documents = await getCollection('documents');
const allTypes = new Set<string>();
for (const d of documents) if (d.data.type) allTypes.add(d.data.type);
---

<PageLayout title="Документи" crumbSegments={['documents']}>
  <slot slot="header">
    <h1 class="header__title header__title--display">Документи</h1>
    <p class="header__subtitle">{documents.length} документ · контракти, політики, чеклисти</p>
  </slot>

  <p class="lead">
    Документи — це контракти, політики й форми. Вони композовані з
    повторно використовуваних пунктів (clauses). Зміна пункту
    автоматично оновлює всі документи, які його містять.
  </p>

  {allTypes.size > 0 && (
    <div class="filter-bar" data-filter-target="type">
      <span class="filter-bar__label">Тип:</span>
      <button class="filter-bar__chip is-active" data-filter-value="all">усі</button>
      {[...allTypes].map((t) => (
        <button class="filter-bar__chip" data-filter-value={t}>{t}</button>
      ))}
    </div>
  )}

  <ul class="content-list" data-filter-list>
    {documents.map((d) => (
      <li data-type={d.data.type} data-tags={(d.data.tags ?? []).join(',')}>
        <a href={`/documents/${d.data.id}`}>{pickTitle(d.data.title)}</a>
        <span class="pill">{d.data.type}</span>
      </li>
    ))}
  </ul>
</PageLayout>
