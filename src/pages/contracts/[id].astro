---
import { getCollection, render } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import MetaBlock from '~/components/MetaBlock.astro';
import LangToggle from '~/components/LangToggle.astro';
import BacklinksSection from '~/components/BacklinksSection.astro';
import PageFooter from '~/components/PageFooter.astro';
import Toc from '~/components/Toc.astro';
import Clause from '~/components/Clause.astro';
import Voice from '~/components/Voice.astro';

const safeGet = async (name: any) => {
  try { return await getCollection(name); } catch { return []; }
};

export async function getStaticPaths() {
  try {
    const all = await getCollection('contracts');
    const bases = new Map<string, any[]>();
    for (const c of all) {
      const base = c.data.baseId || c.data.id;
      if (!bases.has(base)) bases.set(base, []);
      bases.get(base)!.push(c);
    }
    const paths: any[] = [];
    for (const [baseId, variants] of bases) {
      const preferred =
        variants.find((v) => v.data.lang === 'uk') ||
        variants.find((v) => v.data.lang === 'en') ||
        variants[0];
      paths.push({
        params: { id: baseId },
        props: { baseId, variants, lang: preferred.data.lang },
      });
    }
    return paths;
  } catch {
    return [];
  }
}

const { baseId, variants, lang } = Astro.props as {
  baseId: string;
  variants: any[];
  lang: string;
};

const urlLang = Astro.url.searchParams.get('lang');
const currentLang =
  urlLang && variants.some((v) => v.data.lang === urlLang) ? urlLang : lang;
const entry = variants.find((v) => v.data.lang === currentLang) || variants[0];

const { Content, headings } = await render(entry);

const title =
  typeof entry.data.title === 'string'
    ? entry.data.title
    : entry.data.title[currentLang] ||
      entry.data.title.uk ||
      entry.data.title.en ||
      baseId;

const languages = variants.map((v: any) => v.data.lang);
---

<PageLayout
  title={title}
  crumbSegments={['contracts', baseId]}
  lang={currentLang as any}
>
  <slot slot="header">
    <h1 class="header__title">{title}</h1>
    <MetaBlock
      pillar="contract"
      languages={languages}
      status="active"
      updated={entry.data.updated}
    />
    <LangToggle base={`/contracts/${baseId}`} languages={languages} current={currentLang} />

    <div class="view-toggle" role="tablist" aria-label="Режим перегляду">
      <button
        type="button"
        class="view-toggle__btn"
        data-view-btn="clean"
        role="tab"
      >
        <span class="view-toggle__label">Чистий текст</span>
        <span class="view-toggle__hint">лише контракт</span>
      </button>
      <button
        type="button"
        class="view-toggle__btn is-active"
        data-view-btn="reviewed"
        role="tab"
        aria-selected="true"
      >
        <span class="view-toggle__label">З коментарями</span>
        <span class="view-toggle__hint">контракт + голоси</span>
      </button>
      <button
        type="button"
        class="view-toggle__btn"
        data-view-btn="brief"
        role="tab"
      >
        <span class="view-toggle__label">Лише бриф</span>
        <span class="view-toggle__hint">огляд + структура</span>
      </button>
    </div>

    <div class="contract-actions">
      <button type="button" class="contract-actions__btn" data-copy-contract>
        <span data-copy-label>Скопіювати чистий текст</span>
      </button>
    </div>
  </slot>

  <Toc slot="margin" headings={headings} />

  <div class="contract-layout" data-view="reviewed">
    <div class="contract-body" data-contract-source>
      <Content components={{ Clause, Voice }} />
    </div>
  </div>

  <script>
    // View mode toggle — three layers: clean, reviewed, brief.
    // Persists choice in localStorage per page.
    function setupViewToggle() {
      const layout = document.querySelector<HTMLElement>('.contract-layout');
      const buttons = document.querySelectorAll<HTMLButtonElement>('[data-view-btn]');
      if (!layout || buttons.length === 0) return;

      const KEY = 'drafters:contract-view';
      const saved = localStorage.getItem(KEY);
      if (saved && ['clean', 'reviewed', 'brief'].includes(saved)) {
        applyView(saved);
      }

      function applyView(view: string) {
        layout!.setAttribute('data-view', view);
        buttons.forEach((b) => {
          const isActive = b.dataset.viewBtn === view;
          b.classList.toggle('is-active', isActive);
          b.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
      }

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const view = btn.dataset.viewBtn;
          if (!view) return;
          applyView(view);
          localStorage.setItem(KEY, view);
        });
      });
    }

    // "Copy clean contract" — clones the body, strips all tool chrome,
    // voices, briefing, and clause sub-headers, writes plain text to
    // clipboard. Result pastes directly into Word / email with no cleanup.
    function setupCopyContract() {
      const btn = document.querySelector<HTMLButtonElement>('[data-copy-contract]');
      const body = document.querySelector<HTMLElement>('.contract-body');
      if (!btn || !body) return;
      const labelEl = btn.querySelector<HTMLElement>('[data-copy-label]');
      const defaultLabel = labelEl?.textContent ?? 'Скопіювати';

      btn.addEventListener('click', async () => {
        const clone = body.cloneNode(true) as HTMLElement;
        // Remove everything that is NOT part of the signable contract.
        clone.querySelectorAll(
          '.voice, .clause__header, .clause__lang-fallback, .clause__commentary'
        ).forEach((n) => n.remove());
        // Remove the briefing blockquote (always first-of-type at body root).
        const firstBlockquote = clone.querySelector(':scope > blockquote');
        if (firstBlockquote) firstBlockquote.remove();
        // Remove the clause title h3 (first h3 inside each .clause section).
        clone.querySelectorAll('.clause').forEach((c) => {
          const h3 = c.querySelector(':scope > h3');
          if (h3) h3.remove();
        });

        const text = (clone.innerText || '').replace(/\n{3,}/g, '\n\n').trim();
        try {
          await navigator.clipboard.writeText(text);
          if (labelEl) {
            labelEl.textContent = 'Скопійовано ✓';
            setTimeout(() => (labelEl.textContent = defaultLabel), 1800);
          }
        } catch (err) {
          console.error('Copy failed:', err);
          if (labelEl) {
            labelEl.textContent = 'Не вдалося скопіювати';
            setTimeout(() => (labelEl.textContent = defaultLabel), 1800);
          }
        }
      });
    }

    setupViewToggle();
    setupCopyContract();
    document.addEventListener('astro:page-load', () => {
      setupViewToggle();
      setupCopyContract();
    });
  </script>

  <BacklinksSection collection="contracts" id={baseId} />
  <PageFooter editPath={`contracts/${entry.data.id}.mdx`} updated={entry.data.updated} />
</PageLayout>

<style>
  /* ───────────────────────────────────────────────────── */
  /* View toggle UI                                        */
  /* ───────────────────────────────────────────────────── */
  .view-toggle {
    display: inline-flex;
    gap: 0;
    margin-top: 1.2rem;
    border: 1px solid var(--rule);
    background: var(--paper);
  }
  .view-toggle__btn {
    background: transparent;
    border: 0;
    border-right: 1px solid var(--rule);
    padding: 0.6rem 0.9rem;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    font-family: var(--font-sans);
    color: var(--ink-muted);
    transition: background var(--t-base), color var(--t-base);
  }
  .view-toggle__btn:last-child {
    border-right: 0;
  }
  .view-toggle__btn:hover {
    background: var(--lavender-wash);
    color: var(--ink);
  }
  .view-toggle__btn.is-active {
    background: var(--ink);
    color: var(--paper);
  }
  .view-toggle__btn.is-active:hover {
    background: var(--ink);
  }
  .view-toggle__label {
    font-size: var(--fs-small);
    font-weight: var(--fw-bold);
  }
  .view-toggle__hint {
    font-size: 0.7rem;
    opacity: 0.75;
    font-weight: var(--fw-regular);
  }

  /* "Copy clean contract" action, sits beside the view-toggle */
  .contract-actions {
    margin-top: 1rem;
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .contract-actions__btn {
    background: transparent;
    border: 1px solid var(--rule);
    padding: 0.5rem 0.9rem;
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    color: var(--ink-muted);
    cursor: pointer;
    transition: background var(--t-base), color var(--t-base), border-color var(--t-base);
  }
  .contract-actions__btn:hover {
    background: var(--lavender-wash);
    color: var(--ink);
    border-color: var(--lavender);
  }

  /* ───────────────────────────────────────────────────── */
  /* Contract layout: two-column on wide screens           */
  /* ───────────────────────────────────────────────────── */
  .contract-layout {
    position: relative;
  }

  .contract-body {
    max-width: var(--measure);
  }

  .contract-body :global(h1) {
    font-size: var(--fs-h1);
    border-bottom: 2px solid var(--ink);
    padding-bottom: 0.3em;
    margin-bottom: 1em;
  }

  .contract-body :global(h2) {
    font-size: var(--fs-h3);
    font-family: var(--font-sans);
    font-weight: var(--fw-bold);
    margin-top: 2.6em;
    padding-top: 1em;
    border-top: 1px solid var(--rule);
  }

  .contract-body :global(table) {
    width: 100%;
    max-width: 100%;
  }

  /* ───────────────────────────────────────────────────── */
  /* Clause chrome: HIDE inside contract body.             */
  /* The clause header ("clause / baseId") and the clause  */
  /* title <h3> are editor affordances — useful on the     */
  /* standalone /clauses/[id] page but noise when a clause */
  /* is inlined into a real contract. Section numbering    */
  /* comes from the contract's h2; clause bodies flow      */
  /* directly under their section.                         */
  /* ───────────────────────────────────────────────────── */
  .contract-body :global(.clause__header) {
    display: none;
  }
  .contract-body :global(.clause > h3) {
    display: none;
  }
  /* Strip editorial commentary from inlined clauses. Clause MDX bodies
     use h2 sub-headings ("How this works in practice", "Things to watch",
     "Notes", "Where used", etc.) to mark where legal text ends and the
     wiki-style editorial begins. When a clause is inlined into a contract,
     only the legal text above that first h2 should render — the
     standalone /clauses/[id] page is where the editorial belongs.
     A clause that needs sub-structure inside its legal text should use
     bold lead-in paragraphs ("**Term of confidentiality.** ..."), not h2. */
  .contract-body :global(.clause h2),
  .contract-body :global(.clause h2 ~ *) {
    display: none;
  }
  /* Give stacked clauses a minimal separator so they don't run together. */
  .contract-body :global(.clause + .clause) {
    margin-top: 1.2rem;
    padding-top: 1.2rem;
    border-top: 1px dotted var(--rule-soft);
  }

  /* ───────────────────────────────────────────────────── */
  /* Executive summary (briefing). The first blockquote at */
  /* body root is the pre-negotiation brief — style it as  */
  /* a distinct meta panel, not a pull-quote.              */
  /* ───────────────────────────────────────────────────── */
  .contract-body :global(> blockquote:first-of-type) {
    background: var(--paper-soft);
    border-left: 3px solid var(--lavender);
    padding: 1.1rem 1.3rem;
    margin: 1rem 0 2.4rem;
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    line-height: 1.55;
    color: var(--ink);
    quotes: none;
  }
  .contract-body :global(> blockquote:first-of-type::before),
  .contract-body :global(> blockquote:first-of-type::after) {
    content: none;
  }
  .contract-body :global(> blockquote:first-of-type p) {
    margin: 0;
  }

  /* ───────────────────────────────────────────────────── */
  /* DESKTOP LAYOUT — TWO COLUMNS at ≥ 1280px              */
  /* The page grid (layout.css) expands to 13rem + 62rem in  */
  /* reviewed mode. Below 1280px the page frame is too tight  */
  /* to comfortably fit 34rem content + 20rem voices side by  */
  /* side, so we fall back to inline voices (same as mobile). */
  /* ───────────────────────────────────────────────────── */
  @media (min-width: 1280px) {
    .contract-layout[data-view="reviewed"] .contract-body {
      max-width: 62rem;
    }

    /* Non-voice direct children reserve a 20rem voice gutter on the
       right (18rem voice + 2rem left margin). Using calc on the
       parent width makes this robust to viewport changes. */
    .contract-layout[data-view="reviewed"] .contract-body :global(> *:not(.voice)) {
      max-width: calc(100% - 20rem);
    }

    /* Voices float into the right column */
    .contract-layout[data-view="reviewed"] .contract-body :global(.voice) {
      float: right;
      clear: right;
      width: 18rem;
      max-width: 18rem;
      margin: 0.3rem 0 1rem 2rem;
      font-size: var(--fs-meta);
    }

    /* Each new h2 section starts below any preceding floats — keeps
       voices tied to the section they comment on. */
    .contract-layout[data-view="reviewed"] .contract-body :global(> h2) {
      clear: right;
    }
  }

  /* Brief mode: single-column narrow (briefing + headers + voices only) */
  @media (min-width: 1024px) {
    .contract-layout[data-view="brief"] .contract-body {
      max-width: 40rem;
    }
  }

  /* ───────────────────────────────────────────────────── */
  /* CLEAN mode: hide all voices and the briefing callout  */
  /* ───────────────────────────────────────────────────── */
  .contract-layout[data-view="clean"] .contract-body :global(.voice),
  .contract-layout[data-view="clean"] .contract-body :global(> blockquote) {
    display: none;
  }

  /* ───────────────────────────────────────────────────── */
  /* BRIEF mode: pure brief — briefing + section titles    */
  /* only. The h2 list IS the table of contents. No voices,*/
  /* no body prose, no tables, no clauses. A 1-pager for   */
  /* the junior walking into a negotiation.                */
  /* ───────────────────────────────────────────────────── */
  .contract-layout[data-view="brief"] .contract-body :global(> *) {
    display: none;
  }
  .contract-layout[data-view="brief"] .contract-body :global(> h1),
  .contract-layout[data-view="brief"] .contract-body :global(> h2),
  .contract-layout[data-view="brief"] .contract-body :global(> blockquote:first-of-type) {
    display: block;
  }

  /* Brief-mode h2 styling: tighter, no top border — this is a TOC, not a doc. */
  .contract-layout[data-view="brief"] .contract-body :global(> h2) {
    border-top: 0;
    padding-top: 0;
    margin-top: 1.1rem;
    font-size: var(--fs-lead);
  }

  /* Mobile: voices stay inline as full-width cards regardless of view */
  @media (max-width: 1023px) {
    .view-toggle {
      flex-wrap: wrap;
    }
    .view-toggle__btn {
      flex: 1 1 auto;
    }
  }
</style>
