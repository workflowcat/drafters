---
import { getCollection, render } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import MetaBlock from '~/components/MetaBlock.astro';
import LangToggle from '~/components/LangToggle.astro';
import BacklinksSection from '~/components/BacklinksSection.astro';
import PageFooter from '~/components/PageFooter.astro';
import Toc from '~/components/Toc.astro';
import Clause from '~/components/Clause.astro';
import Voice from '~/components/Voice.astro';

const safeGet = async (name: any) => {
  try { return await getCollection(name); } catch { return []; }
};

export async function getStaticPaths() {
  try {
    const all = await getCollection('contracts');
    const bases = new Map<string, any[]>();
    for (const c of all) {
      const base = c.data.baseId || c.data.id;
      if (!bases.has(base)) bases.set(base, []);
      bases.get(base)!.push(c);
    }
    const paths: any[] = [];
    for (const [baseId, variants] of bases) {
      const preferred =
        variants.find((v) => v.data.lang === 'uk') ||
        variants.find((v) => v.data.lang === 'en') ||
        variants[0];
      paths.push({
        params: { id: baseId },
        props: { baseId, variants, lang: preferred.data.lang },
      });
    }
    return paths;
  } catch {
    return [];
  }
}

const { baseId, variants, lang } = Astro.props as {
  baseId: string;
  variants: any[];
  lang: string;
};

const urlLang = Astro.url.searchParams.get('lang');
const currentLang =
  urlLang && variants.some((v) => v.data.lang === urlLang) ? urlLang : lang;
const entry = variants.find((v) => v.data.lang === currentLang) || variants[0];

const { Content, headings } = await render(entry);

const title =
  typeof entry.data.title === 'string'
    ? entry.data.title
    : entry.data.title[currentLang] ||
      entry.data.title.uk ||
      entry.data.title.en ||
      baseId;

const languages = variants.map((v: any) => v.data.lang);
---

<PageLayout
  title={title}
  crumbSegments={['contracts', baseId]}
  lang={currentLang as any}
>
  <slot slot="header">
    <h1 class="header__title">{title}</h1>
    <MetaBlock
      pillar="contract"
      languages={languages}
      status="active"
      updated={entry.data.updated}
    />
    <LangToggle base={`/contracts/${baseId}`} languages={languages} current={currentLang} />

    <div class="view-toggle" role="tablist" aria-label="Режим перегляду">
      <button
        type="button"
        class="view-toggle__btn"
        data-view-btn="clean"
        role="tab"
      >
        <span class="view-toggle__label">Чистий текст</span>
        <span class="view-toggle__hint">лише контракт</span>
      </button>
      <button
        type="button"
        class="view-toggle__btn is-active"
        data-view-btn="reviewed"
        role="tab"
        aria-selected="true"
      >
        <span class="view-toggle__label">З коментарями</span>
        <span class="view-toggle__hint">контракт + голоси</span>
      </button>
      <button
        type="button"
        class="view-toggle__btn"
        data-view-btn="brief"
        role="tab"
      >
        <span class="view-toggle__label">Лише бриф</span>
        <span class="view-toggle__hint">огляд + переговори</span>
      </button>
    </div>
  </slot>

  <Toc slot="margin" headings={headings} />

  <div class="contract-layout" data-view="reviewed">
    <div class="contract-body" data-contract-source>
      <Content components={{ Clause, Voice }} />
    </div>
  </div>

  <script>
    // View mode toggle — three layers: clean, reviewed, brief.
    // Persists choice in localStorage per page.
    function setupViewToggle() {
      const layout = document.querySelector<HTMLElement>('.contract-layout');
      const buttons = document.querySelectorAll<HTMLButtonElement>('[data-view-btn]');
      if (!layout || buttons.length === 0) return;

      const KEY = 'drafters:contract-view';
      const saved = localStorage.getItem(KEY);
      if (saved && ['clean', 'reviewed', 'brief'].includes(saved)) {
        applyView(saved);
      }

      function applyView(view: string) {
        layout!.setAttribute('data-view', view);
        buttons.forEach((b) => {
          const isActive = b.dataset.viewBtn === view;
          b.classList.toggle('is-active', isActive);
          b.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
      }

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const view = btn.dataset.viewBtn;
          if (!view) return;
          applyView(view);
          localStorage.setItem(KEY, view);
        });
      });
    }
    setupViewToggle();
    document.addEventListener('astro:page-load', setupViewToggle);
  </script>

  <BacklinksSection collection="contracts" id={baseId} />
  <PageFooter editPath={`contracts/${entry.data.id}.mdx`} updated={entry.data.updated} />
</PageLayout>

<style>
  /* ───────────────────────────────────────────────────── */
  /* View toggle UI                                        */
  /* ───────────────────────────────────────────────────── */
  .view-toggle {
    display: inline-flex;
    gap: 0;
    margin-top: 1.2rem;
    border: 1px solid var(--rule);
    background: var(--paper);
  }
  .view-toggle__btn {
    background: transparent;
    border: 0;
    border-right: 1px solid var(--rule);
    padding: 0.6rem 0.9rem;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    font-family: var(--font-sans);
    color: var(--ink-muted);
    transition: background var(--t-base), color var(--t-base);
  }
  .view-toggle__btn:last-child {
    border-right: 0;
  }
  .view-toggle__btn:hover {
    background: var(--lavender-wash);
    color: var(--ink);
  }
  .view-toggle__btn.is-active {
    background: var(--ink);
    color: var(--paper);
  }
  .view-toggle__btn.is-active:hover {
    background: var(--ink);
  }
  .view-toggle__label {
    font-size: var(--fs-small);
    font-weight: var(--fw-bold);
  }
  .view-toggle__hint {
    font-size: 0.7rem;
    opacity: 0.75;
    font-weight: var(--fw-regular);
  }

  /* ───────────────────────────────────────────────────── */
  /* Contract layout: two-column on wide screens           */
  /* ───────────────────────────────────────────────────── */
  .contract-layout {
    position: relative;
  }

  .contract-body {
    max-width: var(--measure);
  }

  .contract-body :global(h1) {
    font-size: var(--fs-h1);
    border-bottom: 2px solid var(--ink);
    padding-bottom: 0.3em;
    margin-bottom: 1em;
  }

  .contract-body :global(h2) {
    font-size: var(--fs-h3);
    font-family: var(--font-sans);
    font-weight: var(--fw-bold);
    margin-top: 2.6em;
    padding-top: 1em;
    border-top: 1px solid var(--rule);
  }

  .contract-body :global(table) {
    width: 100%;
    max-width: 100%;
  }

  /* ───────────────────────────────────────────────────── */
  /* DESKTOP LAYOUT (≥ 1024px): two columns                */
  /* ───────────────────────────────────────────────────── */
  @media (min-width: 1024px) {
    /* Reviewed mode: widen the contract body container so voices can
       float into a dedicated right column. Contract text itself stays
       narrow (40rem) for readability. */
    .contract-layout[data-view="reviewed"] .contract-body,
    .contract-layout[data-view="brief"] .contract-body {
      max-width: 62rem;
    }

    /* Keep actual contract text elements at a readable measure */
    .contract-layout[data-view="reviewed"] .contract-body :global(> p),
    .contract-layout[data-view="reviewed"] .contract-body :global(> h2),
    .contract-layout[data-view="reviewed"] .contract-body :global(> h3),
    .contract-layout[data-view="reviewed"] .contract-body :global(> ul),
    .contract-layout[data-view="reviewed"] .contract-body :global(> ol),
    .contract-layout[data-view="reviewed"] .contract-body :global(> blockquote),
    .contract-layout[data-view="reviewed"] .contract-body :global(> table),
    .contract-layout[data-view="reviewed"] .contract-body :global(.clause) {
      max-width: 40rem;
    }

    /* Voices float into the right column */
    .contract-layout[data-view="reviewed"] .contract-body :global(.voice) {
      float: right;
      clear: right;
      width: 18rem;
      max-width: 18rem;
      margin: 0.3rem 0 1rem 1.5rem;
      font-size: var(--fs-meta);
    }

    /* Subtle vertical divider between text and voices */
    .contract-layout[data-view="reviewed"] .contract-body::before {
      content: '';
      position: absolute;
      top: 0;
      bottom: 0;
      left: 41.5rem;
      width: 1px;
      background: var(--rule-soft);
      pointer-events: none;
    }
  }

  /* ───────────────────────────────────────────────────── */
  /* CLEAN mode: hide all voices, text widens              */
  /* ───────────────────────────────────────────────────── */
  .contract-layout[data-view="clean"] .contract-body :global(.voice),
  .contract-layout[data-view="clean"] .contract-body :global(blockquote:first-of-type) {
    display: none;
  }

  /* ───────────────────────────────────────────────────── */
  /* BRIEF mode: hide legal body text, keep headers + voices */
  /* ───────────────────────────────────────────────────── */
  .contract-layout[data-view="brief"] .contract-body :global(h1),
  .contract-layout[data-view="brief"] .contract-body :global(h2),
  .contract-layout[data-view="brief"] .contract-body :global(blockquote:first-of-type),
  .contract-layout[data-view="brief"] .contract-body :global(.voice) {
    display: block;
  }

  .contract-layout[data-view="brief"] .contract-body :global(p),
  .contract-layout[data-view="brief"] .contract-body :global(ul),
  .contract-layout[data-view="brief"] .contract-body :global(ol),
  .contract-layout[data-view="brief"] .contract-body :global(table),
  .contract-layout[data-view="brief"] .contract-body :global(.clause),
  .contract-layout[data-view="brief"] .contract-body :global(hr),
  .contract-layout[data-view="brief"] .contract-body :global(h3) {
    display: none;
  }

  /* But keep the brief blockquote visible */
  .contract-layout[data-view="brief"] .contract-body :global(blockquote:first-of-type) {
    display: block !important;
  }

  /* In brief mode voices stay in left column (no float) */
  @media (min-width: 1024px) {
    .contract-layout[data-view="brief"] .contract-body :global(.voice) {
      float: none;
      clear: none;
      width: auto;
      max-width: 100%;
      margin: 0.6rem 0;
      font-size: var(--fs-small);
    }
  }

  /* Mobile: voices stay inline as full-width cards regardless of view */
  @media (max-width: 1023px) {
    .view-toggle {
      flex-wrap: wrap;
    }
    .view-toggle__btn {
      flex: 1 1 auto;
    }
  }
</style>
