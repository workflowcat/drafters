---
import { getCollection, render } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import MetaBlock from '~/components/MetaBlock.astro';
import LangToggle from '~/components/LangToggle.astro';
import BacklinksSection from '~/components/BacklinksSection.astro';
import PageFooter from '~/components/PageFooter.astro';
import Toc from '~/components/Toc.astro';
import Clause from '~/components/Clause.astro';
import Voice from '~/components/Voice.astro';
import { pickTitle } from '~/lib/collection-helpers';

const safeGet = async (name: any) => {
  try { return await getCollection(name); } catch { return []; }
};

export async function getStaticPaths() {
  try {
    const all = await getCollection('contracts');
    // Group by baseId
    const bases = new Map<string, any[]>();
    for (const c of all) {
      const base = c.data.baseId || c.data.id;
      if (!bases.has(base)) bases.set(base, []);
      bases.get(base)!.push(c);
    }
    const paths: any[] = [];
    for (const [baseId, variants] of bases) {
      const preferred =
        variants.find((v) => v.data.lang === 'uk') ||
        variants.find((v) => v.data.lang === 'en') ||
        variants[0];
      paths.push({
        params: { id: baseId },
        props: { baseId, variants, lang: preferred.data.lang },
      });
    }
    return paths;
  } catch {
    return [];
  }
}

const { baseId, variants, lang } = Astro.props as {
  baseId: string;
  variants: any[];
  lang: string;
};

const urlLang = Astro.url.searchParams.get('lang');
const currentLang =
  urlLang && variants.some((v) => v.data.lang === urlLang) ? urlLang : lang;
const entry = variants.find((v) => v.data.lang === currentLang) || variants[0];

const { Content, headings } = await render(entry);

const title =
  typeof entry.data.title === 'string'
    ? entry.data.title
    : entry.data.title[currentLang] ||
      entry.data.title.uk ||
      entry.data.title.en ||
      baseId;

const languages = variants.map((v: any) => v.data.lang);
---

<PageLayout
  title={title}
  crumbSegments={['contracts', baseId]}
  lang={currentLang as any}
>
  <slot slot="header">
    <h1 class="header__title">{title}</h1>
    <MetaBlock
      pillar="contract"
      languages={languages}
      status="active"
      updated={entry.data.updated}
    />
    <LangToggle base={`/contracts/${baseId}`} languages={languages} current={currentLang} />
    <div class="header__actions">
      <span class="pill">повний контракт · готовий до підпису</span>
    </div>
  </slot>

  <Toc slot="margin" headings={headings} />

  <div class="contract-body" data-contract-source>
    <Content components={{ Clause, Voice }} />
  </div>

  <dialog class="preview-dialog" data-preview-dialog>
    <form method="dialog" class="preview-dialog__bar">
      <div class="preview-dialog__bar-left">
        <span class="preview-dialog__label">Попередній перегляд</span>
        <span class="preview-dialog__title">{title}</span>
        <span class="preview-dialog__lang">· {currentLang}</span>
      </div>
      <div class="preview-dialog__bar-right">
        <a
          class="btn btn--primary"
          href={`/exports/contracts/${baseId}/contract.${currentLang}.docx`}
          download
          data-preview-download
        >
          Завантажити .docx
        </a>
        <button class="btn btn--ghost" type="button" data-preview-print>
          Друк
        </button>
        <button class="btn btn--ghost" type="submit" aria-label="Закрити">
          ✕
        </button>
      </div>
    </form>
    <div class="preview-dialog__paper-wrap">
      <article class="preview-dialog__paper" data-preview-target>
        <p class="preview-dialog__placeholder">…</p>
      </article>
    </div>
  </dialog>

  <script>
    // Contract export preview modal.
    // Clones the already-rendered .contract-body into a paper-styled
    // dialog so the user sees exactly what the .docx will look like
    // before downloading. Kept client-side so no extra build pipeline.
    function setupContractPreview() {
      const openBtn = document.querySelector<HTMLButtonElement>('[data-preview-open]');
      const dialog = document.querySelector<HTMLDialogElement>('[data-preview-dialog]');
      const source = document.querySelector<HTMLElement>('[data-contract-source]');
      const target = document.querySelector<HTMLElement>('[data-preview-target]');
      const printBtn = document.querySelector<HTMLButtonElement>('[data-preview-print]');
      const downloadBtn = document.querySelector<HTMLAnchorElement>('[data-preview-download]');
      if (!openBtn || !dialog || !source || !target) return;

      function highlightClauses(root: HTMLElement) {
        const clauses = root.querySelectorAll<HTMLElement>('.clause, section, h2');
        clauses.forEach((el, i) => {
          setTimeout(() => {
            el.style.transition = 'background 220ms ease, outline 220ms ease';
            el.style.background = 'color-mix(in srgb, var(--lavender) 22%, transparent)';
            el.style.outline = '2px solid var(--lavender)';
            el.style.outlineOffset = '4px';
            setTimeout(() => {
              el.style.background = '';
              el.style.outline = '';
              el.style.outlineOffset = '';
            }, 420);
          }, i * 40);
        });
      }

      openBtn.addEventListener('click', () => {
        // Clone the live contract body into the modal target
        target.innerHTML = '';
        const clone = source.cloneNode(true) as HTMLElement;
        // Strip any data hooks that shouldn't be in the static preview
        clone.removeAttribute('data-contract-source');
        while (clone.firstChild) target.appendChild(clone.firstChild);
        dialog.showModal();
        // Delayed highlight to show what's being bundled
        requestAnimationFrame(() => highlightClauses(target));
      });

      // Click on backdrop closes it
      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) dialog.close();
      });

      // Escape key already handled by <dialog> natively

      if (printBtn) {
        printBtn.addEventListener('click', () => {
          // Add a temporary print class to document, restore on afterprint
          document.body.classList.add('is-printing-preview');
          window.print();
          setTimeout(() => {
            document.body.classList.remove('is-printing-preview');
          }, 300);
        });
      }

      if (downloadBtn) {
        downloadBtn.addEventListener('click', () => {
          highlightClauses(target);
        });
      }
    }
    setupContractPreview();
    document.addEventListener('astro:page-load', setupContractPreview);
  </script>

  <BacklinksSection collection="contracts" id={baseId} />
  <PageFooter editPath={`contracts/${entry.data.id}.mdx`} updated={entry.data.updated} />
</PageLayout>

<style>
  .contract-body {
    max-width: var(--measure);
  }
  .contract-body :global(h1) {
    font-size: var(--fs-h1);
    border-bottom: 2px solid var(--ink);
    padding-bottom: 0.3em;
    margin-bottom: 1em;
  }
  .contract-body :global(h2) {
    font-size: var(--fs-h3);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    font-family: var(--font-sans);
    font-weight: var(--fw-bold);
    margin-top: 2.6em;
    padding-top: 1em;
    border-top: 1px solid var(--rule);
  }
  .contract-body :global(table) {
    width: 100%;
    max-width: 100%;
  }

  /* --- Preview dialog --- */
  .preview-dialog {
    border: none;
    padding: 0;
    background: var(--paper-soft);
    width: min(920px, 96vw);
    max-width: none;
    max-height: 92vh;
    box-shadow: 0 20px 60px color-mix(in srgb, var(--ink) 28%, transparent);
    color: var(--ink);
    overflow: hidden;
  }
  .preview-dialog::backdrop {
    background: color-mix(in srgb, var(--ink) 55%, transparent);
    backdrop-filter: blur(2px);
  }
  .preview-dialog[open] {
    display: flex;
    flex-direction: column;
  }

  .preview-dialog__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.8rem 1.2rem;
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
    position: sticky;
    top: 0;
    z-index: 2;
    flex-wrap: wrap;
  }
  .preview-dialog__bar-left {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
    min-width: 0;
  }
  .preview-dialog__label {
    font-family: var(--font-sans);
    font-weight: var(--fw-bold);
    font-size: var(--fs-meta);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-faint);
  }
  .preview-dialog__title {
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    color: var(--ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 28rem;
  }
  .preview-dialog__lang {
    font-family: var(--font-sans);
    font-size: var(--fs-meta);
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
  }
  .preview-dialog__bar-right {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .preview-dialog__paper-wrap {
    overflow-y: auto;
    overflow-x: hidden;
    padding: 2rem 1.2rem 3rem;
    flex: 1;
    background:
      linear-gradient(180deg,
        color-mix(in srgb, var(--ink) 4%, transparent) 0,
        transparent 3rem);
  }
  .preview-dialog__paper {
    background: #fffdf8;
    color: #1a1a1a;
    max-width: 680px;
    margin: 0 auto;
    padding: 3.2rem 3.4rem 4rem;
    box-shadow:
      0 1px 0 color-mix(in srgb, var(--ink) 12%, transparent),
      0 8px 28px color-mix(in srgb, var(--ink) 18%, transparent);
    font-family: var(--font-serif);
    font-size: calc(var(--fs-small) * 1.02);
    line-height: 1.55;
    min-height: 50vh;
  }
  .preview-dialog__paper :global(h1) {
    font-size: 1.8rem;
    border-bottom: 2px solid #1a1a1a;
    padding-bottom: 0.3em;
    margin: 0 0 1em;
  }
  .preview-dialog__paper :global(h2) {
    font-family: var(--font-sans);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    font-weight: var(--fw-bold);
    margin-top: 2.2em;
    padding-top: 0.9em;
    border-top: 1px solid color-mix(in srgb, #1a1a1a 20%, transparent);
  }
  .preview-dialog__paper :global(h3) {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    margin-top: 1.6em;
  }
  .preview-dialog__paper :global(p) {
    margin: 0.8em 0;
  }
  .preview-dialog__paper :global(ul),
  .preview-dialog__paper :global(ol) {
    padding-left: 1.4em;
  }
  .preview-dialog__paper :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1em 0;
    font-size: 0.95em;
  }
  .preview-dialog__paper :global(th),
  .preview-dialog__paper :global(td) {
    border: 1px solid color-mix(in srgb, #1a1a1a 25%, transparent);
    padding: 0.4em 0.6em;
    text-align: left;
  }
  .preview-dialog__paper :global(.clause) {
    position: relative;
  }
  .preview-dialog__placeholder {
    color: var(--ink-faint);
    font-style: italic;
    text-align: center;
    padding: 2rem 0;
  }

  @media (max-width: 640px) {
    .preview-dialog__paper {
      padding: 2rem 1.4rem 2.6rem;
    }
    .preview-dialog__paper-wrap {
      padding: 1rem 0.6rem 2rem;
    }
  }

  /* Print: when the preview dialog is open and user prints,
     hide everything outside the paper. */
  @media print {
    body.is-printing-preview {
      background: white;
    }
    body.is-printing-preview .layout,
    body.is-printing-preview .header,
    body.is-printing-preview .preview-dialog__bar,
    body.is-printing-preview .contract-body {
      display: none !important;
    }
    body.is-printing-preview .preview-dialog {
      position: static !important;
      display: block !important;
      box-shadow: none;
      width: auto;
      max-width: none;
      max-height: none;
      background: white;
    }
    body.is-printing-preview .preview-dialog__paper-wrap {
      overflow: visible;
      padding: 0;
      background: white;
    }
    body.is-printing-preview .preview-dialog__paper {
      box-shadow: none;
      margin: 0;
      padding: 1.5cm 1.8cm;
      max-width: none;
    }
  }
</style>
