---
import { getCollection } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import { pickTitle } from '~/lib/collection-helpers';

const safeGet = async (name: any) => {
  try {
    return await getCollection(name);
  } catch {
    return [];
  }
};

const cases = await safeGet('cases');
---

<PageLayout title="Кейси" crumbSegments={['cases']}>
  <slot slot="header">
    <h1 class="header__title header__title--display">Кейси</h1>
    <p class="header__subtitle">{cases.length} кейс · сценарні групи процесів</p>
  </slot>

  <p class="lead">
    Кейси — це сценарні групування процесів, які "йдуть разом" у
    реальних ситуаціях. Один кейс може посилатися на декілька
    workflow з різних пілларів і показувати, як вони координуються
    у часі.
  </p>

  {cases.length === 0 ? (
    <p>Поки що немає кейсів.</p>
  ) : (
    <ul class="content-list">
      {cases.map((c: any) => (
        <li>
          <a href={`/cases/${c.data.id}`}>{pickTitle(c.data.title)}</a>
          <span class="pill">{(c.data.workflows ?? []).length} процеси</span>
        </li>
      ))}
    </ul>
  )}
</PageLayout>
