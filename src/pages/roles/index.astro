---
import { getCollection } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import { pickTitle, pickShort } from '~/lib/collection-helpers';

const roles = await getCollection('roles');
---

<PageLayout title="Ролі" crumbSegments={['roles']}>
  <slot slot="header">
    <h1 class="header__title header__title--display">Ролі</h1>
    <p class="header__subtitle">{roles.length} ролі · актори у процесах</p>
  </slot>

  <p class="lead">
    Ролі — це повторно використовувані актори, до яких посилаються
    кроки процесів. Tech Lead, PM, Legal, IT Ops і так далі.
  </p>

  <dl class="term-list">
    {roles.map((r) => (
      <div>
        <dt>
          <a href={`/roles/${r.data.id}`}>{pickTitle(r.data.title)}</a>
        </dt>
        {r.data.short && <dd>{pickShort(r.data.short)}</dd>}
      </div>
    ))}
  </dl>
</PageLayout>

<style>
  .term-list {
    margin: 1rem 0 2rem;
    max-width: var(--measure);
  }
  .term-list > div {
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .term-list > div:last-child { border-bottom: 0; }
  .term-list dt a {
    font-family: var(--font-serif);
    font-size: var(--fs-lead);
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--lavender) 55%, transparent);
    transition: color var(--t-base), border-color var(--t-base);
  }
  .term-list dt a:hover {
    color: var(--lavender-dim);
    border-bottom-color: var(--lavender-dim);
  }
  .term-list dd {
    margin: 0.3rem 0 0;
    color: var(--ink-muted);
    font-style: italic;
    font-size: var(--fs-small);
    max-width: 48rem;
  }
</style>
