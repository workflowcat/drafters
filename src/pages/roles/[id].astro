---
import { getCollection, render } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import BacklinksSection from '~/components/BacklinksSection.astro';
import MetaBlock from '~/components/MetaBlock.astro';

export async function getStaticPaths() {
  const roles = await getCollection('roles');
  return roles.map((r) => ({ params: { id: r.data.id }, props: { entry: r } }));
}

const { entry } = Astro.props as { entry: any };
const { Content } = await render(entry);

const title =
  typeof entry.data.title === 'string'
    ? entry.data.title
    : entry.data.title?.uk || entry.data.title?.en || entry.data.id;
---

<PageLayout title={title} crumbSegments={['roles', entry.data.id]}>
  <slot slot="header">
    <h1 class="header__title">{title}</h1>
    <MetaBlock pillar="role" />
  </slot>

  <Content />

  <BacklinksSection collection="roles" id={entry.data.id} />
</PageLayout>
