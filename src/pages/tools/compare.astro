---
import { getCollection, render } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import Clause from '~/components/Clause.astro';
import { listClauseBases } from '~/lib/clause-variants';

const bases = await listClauseBases();

// Read ?a=baseId&b=baseId from URL
const a = Astro.url.searchParams.get('a');
const b = Astro.url.searchParams.get('b');
const lang = (Astro.url.searchParams.get('lang') || 'uk') as 'uk' | 'en';

function pickTitle(t: any): string {
  if (typeof t === 'string') return t;
  return t?.uk || t?.en || t?.de || '';
}

const options = bases.map((x) => ({
  baseId: x.baseId,
  label: pickTitle(x.preferred.data.title),
  tags: (x.preferred.data.tags ?? []) as string[],
}));

const aValid = !!a && bases.some((x) => x.baseId === a);
const bValid = !!b && bases.some((x) => x.baseId === b);

// Pre-render both clause bodies so JS isn't required
async function renderClause(baseId: string) {
  const hit = bases.find((x) => x.baseId === baseId);
  if (!hit) return null;
  const variant =
    hit.variants && Array.isArray(hit.variants)
      ? (hit.variants as any[]).find((v: any) => v.data.lang === lang) ?? hit.preferred
      : hit.preferred;
  const { Content } = await render(variant);
  return { entry: variant, Content, title: pickTitle(variant.data.title) };
}

// listClauseBases doesn't return variants. Build manually.
const allClauses = await getCollection('clauses');
function variantsFor(baseId: string) {
  return allClauses.filter((c) => (c.data.baseId || c.data.id) === baseId);
}
function pickVariant(baseId: string, lang: string) {
  const vs = variantsFor(baseId);
  return (
    vs.find((v) => v.data.lang === lang) ||
    vs.find((v) => v.data.lang === 'uk') ||
    vs[0]
  );
}

const aEntry = aValid ? pickVariant(a!, lang) : null;
const bEntry = bValid ? pickVariant(b!, lang) : null;
const aContent = aEntry ? (await render(aEntry)).Content : null;
const bContent = bEntry ? (await render(bEntry)).Content : null;
const aTitle = aEntry ? pickTitle(aEntry.data.title) : null;
const bTitle = bEntry ? pickTitle(bEntry.data.title) : null;
---

<PageLayout title="Порівняння пунктів" crumbSegments={['tools', 'compare']}>
  <slot slot="header">
    <h1 class="header__title">Порівняння пунктів</h1>
    <p class="header__subtitle">Виберіть два пункти, щоб побачити їх поруч</p>
  </slot>

  <form class="compare-form" method="get">
    <div class="compare-form__row">
      <label>
        <span class="label">Ліва колонка</span>
        <select name="a">
          <option value="">— вибрати —</option>
          {options.map((o) => (
            <option value={o.baseId} selected={o.baseId === a}>{o.label}</option>
          ))}
        </select>
      </label>
      <label>
        <span class="label">Права колонка</span>
        <select name="b">
          <option value="">— вибрати —</option>
          {options.map((o) => (
            <option value={o.baseId} selected={o.baseId === b}>{o.label}</option>
          ))}
        </select>
      </label>
      <label>
        <span class="label">Мова</span>
        <select name="lang">
          <option value="uk" selected={lang === 'uk'}>uk</option>
          <option value="en" selected={lang === 'en'}>en</option>
        </select>
      </label>
      <button type="submit" class="btn btn--primary">Порівняти</button>
    </div>
  </form>

  {aContent && bContent ? (
    <div class="compare-grid">
      <section class="compare-col">
        <h2>{aTitle}</h2>
        <a href={`/clauses/${a}`} class="btn btn--ghost">Повна стаття →</a>
        <aContent />
      </section>
      <section class="compare-col">
        <h2>{bTitle}</h2>
        <a href={`/clauses/${b}`} class="btn btn--ghost">Повна стаття →</a>
        <bContent />
      </section>
    </div>
  ) : (
    <p class="lead">
      Виберіть два пункти у формі вище. Corisно для порівняння варіантів
      одного пункту (наприклад, <a href="/tools/compare?a=ip-assignment&b=ip-assignment-services">
      IP Assignment (strict) vs IP Assignment (services)
      </a>) або для перегляду дзеркальних напрямків (<a href="/tools/compare?a=payment-dispute&b=payment-dispute-client">
      Payment Dispute vs Payment Dispute (client-facing)
      </a>).
    </p>
  )}
</PageLayout>

<style>
  .compare-form {
    margin: 2rem 0;
    padding: 1.2rem;
    background: var(--paper-soft);
    border: 1px solid var(--rule);
    max-width: 100%;
  }
  .compare-form__row {
    display: grid;
    grid-template-columns: 2fr 2fr 0.6fr auto;
    gap: 1rem;
    align-items: end;
  }
  .compare-form label {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .compare-form .label {
    font-family: var(--font-sans);
    font-size: var(--fs-meta);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-faint);
  }
  .compare-form select {
    padding: 0.55rem 0.6rem;
    border: 1px solid var(--rule);
    background: var(--paper);
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    color: var(--ink);
  }
  @media (max-width: 900px) {
    .compare-form__row { grid-template-columns: 1fr; }
  }

  .compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin: 2rem 0;
    max-width: 100%;
  }
  @media (max-width: 900px) {
    .compare-grid { grid-template-columns: 1fr; }
  }
  .compare-col {
    max-width: none;
    border-left: 2px solid var(--lavender);
    padding-left: 1.2rem;
  }
  .compare-col h2 {
    font-family: var(--font-serif);
    font-size: var(--fs-h3);
    font-weight: var(--fw-semibold);
    margin-top: 0;
  }
  .compare-col :global(p),
  .compare-col :global(ul),
  .compare-col :global(ol) {
    max-width: none;
    font-size: var(--fs-small);
    line-height: 1.55;
  }
  .compare-col :global(h2),
  .compare-col :global(h3) {
    font-size: var(--fs-body);
    margin-top: 1.4rem;
  }
</style>
