---
import PageLayout from '~/layouts/PageLayout.astro';
---

<PageLayout title="Contract builder" crumbSegments={['tools', 'builder']}>
  <slot slot="header">
    <h1 class="header__title header__title--display">Contract builder</h1>
    <p class="header__subtitle">
      Зберіть власний контракт з повторно використовуваних пунктів
    </p>
  </slot>

  <p class="lead">
    Виберіть пункти зліва, упорядкуйте справа, завантажте результат
    як <code>.md</code>. Для <code>.docx</code> — починайте з
    готового шаблону внизу сторінки і модифікуйте.
  </p>

  <div class="builder" data-builder>
    <div class="builder__loading" data-builder-loading>
      Завантаження пунктів…
    </div>

    <div class="builder__app" data-builder-app hidden>
      <div class="builder__controls">
        <label>
          <span class="label">Мова</span>
          <select data-b-lang>
            <option value="uk">uk</option>
            <option value="en">en</option>
          </select>
        </label>
        <label>
          <span class="label">Назва контракту</span>
          <input type="text" data-b-title value="Custom Contract" />
        </label>
      </div>

      <div class="builder__presets-bar">
        <div class="builder__presets-bar-group">
          <span class="label">Шаблони</span>
          <button class="btn btn--ghost" data-b-save>+ зберегти поточний</button>
          <select data-b-load>
            <option value="">— відкрити —</option>
          </select>
          <button class="btn btn--ghost" data-b-delete disabled>× видалити</button>
        </div>
        <div class="builder__presets-bar-group">
          <label class="builder__compare-label">
            <span class="label">Порівняти з</span>
            <select data-b-compare>
              <option value="">— немає —</option>
            </select>
          </label>
        </div>
      </div>

      <div class="builder__grid" data-b-grid>
        <section class="builder__library">
          <header>
            <span class="label">Бібліотека пунктів</span>
            <input type="search" placeholder="Пошук…" data-b-search />
          </header>
          <div class="builder__tag-chips" data-b-tag-chips></div>
          <ul class="builder__clause-list" data-b-library></ul>
        </section>

        <section class="builder__selection">
          <header>
            <span class="label" data-b-count>Ваш контракт (0)</span>
            <button class="btn btn--ghost" data-b-clear>очистити</button>
          </header>
          <ol class="builder__selected-list" data-b-selected>
            <li class="builder__empty">Клацніть пункт ліворуч, щоб додати</li>
          </ol>
          <div class="builder__actions">
            <button class="btn btn--primary" data-b-download-md>
              Завантажити .md
            </button>
            <button class="btn btn--ghost" data-b-download-html>
              .html
            </button>
            <button class="btn btn--ghost" data-b-copy-url>
              Копіювати URL
            </button>
          </div>
        </section>

        <section class="builder__preview">
          <header>
            <span class="label" data-b-preview-label>Попередній перегляд</span>
          </header>
          <div class="builder__preview-body" data-b-preview>
            <p class="builder__empty">Попередній перегляд з'явиться тут</p>
          </div>
        </section>

        <section class="builder__preview builder__preview--compare" data-b-compare-pane hidden>
          <header>
            <span class="label" data-b-compare-label>Порівняння</span>
            <button class="btn btn--ghost" data-b-compare-close>×</button>
          </header>
          <div class="builder__preview-body" data-b-compare-body>
            <p class="builder__empty">Порівняння з'явиться тут</p>
          </div>
        </section>
      </div>

      <div class="builder__presets">
        <p class="label">Починати з існуючого контракту? Відкрийте:</p>
        <div class="builder__preset-links">
          <a class="btn btn--ghost" href="/contracts/subcontract-dev-2026">Subcontract Dev</a>
          <a class="btn btn--ghost" href="/contracts/subcontract-pm-2026">Subcontract PM</a>
          <a class="btn btn--ghost" href="/contracts/subcontract-marketing-2026">Subcontract Marketing</a>
          <a class="btn btn--ghost" href="/contracts/services-agreement-sloboda-2026">Services Agreement</a>
          <a class="btn btn--ghost" href="/contracts/nda-general">NDA</a>
        </div>
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .builder {
    margin: 2rem 0;
  }
  .builder__loading {
    padding: 3rem 1rem;
    text-align: center;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-faint);
  }

  .builder__controls {
    display: flex;
    gap: 1.4rem;
    margin-bottom: 1.4rem;
    flex-wrap: wrap;
  }
  .builder__controls label {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .builder__controls .label {
    font-family: var(--font-sans);
    font-weight: var(--fw-bold);
    font-size: var(--fs-meta);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-faint);
  }
  .builder__controls select,
  .builder__controls input {
    padding: 0.5rem 0.7rem;
    border: 1px solid var(--rule);
    background: var(--paper);
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    color: var(--ink);
    min-width: 14rem;
  }

  .builder__presets-bar {
    display: flex;
    gap: 2rem;
    align-items: center;
    flex-wrap: wrap;
    padding: 0.8rem 1rem;
    margin-bottom: 1rem;
    border: 1px solid var(--rule);
    background: var(--paper-soft);
  }
  .builder__presets-bar-group {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .builder__presets-bar .label {
    font-family: var(--font-sans);
    font-weight: var(--fw-bold);
    font-size: var(--fs-meta);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-faint);
  }
  .builder__presets-bar select {
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--rule);
    background: var(--paper);
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    color: var(--ink);
    min-width: 12rem;
  }
  .builder__compare-label {
    display: flex;
    gap: 0.6rem;
    align-items: center;
  }

  .builder__grid {
    display: grid;
    grid-template-columns: 1.1fr 1.1fr 1.3fr;
    gap: 1rem;
    min-height: 30rem;
  }
  .builder__grid--compare {
    grid-template-columns: 1fr 1fr 1.2fr 1.2fr;
  }
  @media (max-width: 1200px) {
    .builder__grid--compare {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 1024px) {
    .builder__grid,
    .builder__grid--compare {
      grid-template-columns: 1fr;
    }
  }
  .builder__grid section {
    border: 1px solid var(--rule);
    background: var(--paper-soft);
    padding: 1rem 1.2rem;
    display: flex;
    flex-direction: column;
    min-height: 30rem;
    max-height: 60rem;
  }
  .builder__grid header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.6rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 0.8rem;
  }
  .builder__grid .label {
    font-family: var(--font-sans);
    font-weight: var(--fw-bold);
    font-size: var(--fs-meta);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink);
  }

  .builder__library input[type='search'] {
    flex: 0 0 8rem;
    padding: 0.3rem 0.5rem;
    border: 1px solid var(--rule);
    background: var(--paper);
    font-size: var(--fs-meta);
  }
  .builder__tag-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-bottom: 0.8rem;
  }
  .builder__tag-chips button {
    padding: 0.2em 0.5em;
    font-family: var(--font-sans);
    font-size: calc(var(--fs-meta) * 0.95);
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink-muted);
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
  }
  .builder__tag-chips button.is-active {
    background: var(--lavender);
    border-color: var(--lavender);
    color: var(--ink);
  }

  .builder__clause-list,
  .builder__selected-list {
    list-style: none;
    padding: 0;
    margin: 0;
    overflow-y: auto;
    flex: 1;
  }
  .builder__clause-list li,
  .builder__selected-list li {
    padding: 0.6rem 0.6rem;
    border-bottom: 1px dashed var(--rule);
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.6rem;
    transition: background var(--t-base);
  }
  .builder__clause-list li:hover {
    background: var(--lavender-wash);
  }
  .builder__clause-list li.is-selected {
    background: color-mix(in srgb, var(--lavender) 15%, transparent);
    color: var(--ink-muted);
  }
  .builder__clause-list li .b-tags {
    font-family: var(--font-sans);
    font-size: var(--fs-meta);
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
  }
  .builder__selected-list {
    counter-reset: sel;
  }
  .builder__selected-list li {
    counter-increment: sel;
  }
  .builder__selected-list li::before {
    content: counter(sel, decimal-leading-zero) '.';
    font-family: var(--font-sans);
    color: var(--lavender-dim);
    font-weight: var(--fw-bold);
    margin-right: 0.5rem;
  }
  .builder__selected-list li .b-ctrls {
    display: flex;
    gap: 0.2rem;
  }
  .builder__selected-list li .b-ctrls button {
    background: transparent;
    border: 1px solid var(--rule);
    padding: 0.1rem 0.4rem;
    cursor: pointer;
    color: var(--ink-muted);
    font-size: var(--fs-meta);
  }
  .builder__selected-list li .b-ctrls button:hover {
    color: var(--ink);
    background: var(--lavender-wash);
  }
  .builder__empty {
    padding: 1rem;
    color: var(--ink-faint);
    font-style: italic;
    text-align: center;
  }

  .builder__preview {
    min-height: 30rem;
  }
  .builder__preview-body {
    overflow-y: auto;
    flex: 1;
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    line-height: 1.55;
    padding-right: 0.4rem;
    min-width: 0;
    overflow-wrap: break-word;
  }
  .builder__preview-body h1 {
    font-size: 1.4rem;
  }
  .builder__preview-body h2 {
    font-size: 1.1rem;
    margin-top: 1.2em;
    padding-top: 0.6em;
    border-top: 1px solid var(--rule);
  }
  .builder__preview--compare {
    background: color-mix(in srgb, var(--lavender-wash) 55%, var(--paper-soft)) !important;
  }
  .builder__preview--compare header button {
    background: transparent;
    border: 1px solid var(--rule);
    padding: 0.15rem 0.5rem;
    cursor: pointer;
    color: var(--ink-muted);
    font-size: var(--fs-meta);
  }
  .builder__preview-body :global(.diff-line) {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: calc(var(--fs-meta) * 1.02);
    padding: 0.05rem 0.3rem;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .builder__preview-body :global(.diff-line--ctx) {
    color: var(--ink-muted);
  }
  .builder__preview-body :global(.diff-line--add) {
    background: color-mix(in srgb, #7cb07c 22%, transparent);
    color: #1f4a1f;
  }
  .builder__preview-body :global(.diff-line--del) {
    background: color-mix(in srgb, #c88080 22%, transparent);
    color: #5a1f1f;
  }

  .builder__actions {
    display: flex;
    gap: 0.6rem;
    padding-top: 0.8rem;
    border-top: 1px solid var(--rule);
    margin-top: 0.8rem;
  }

  .builder__presets {
    margin-top: 2rem;
    padding: 1.2rem;
    background: var(--paper-soft);
    border: 1px solid var(--rule);
  }
  .builder__presets .label {
    font-family: var(--font-sans);
    font-weight: var(--fw-bold);
    font-size: var(--fs-meta);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-faint);
    margin: 0 0 0.8rem;
  }
  .builder__preset-links {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
</style>

<script>
  interface ClauseEntry {
    title: any;
    tags: string[];
    commentary: string | null;
    variants: Record<string, string>;
  }
  type Manifest = Record<string, ClauseEntry>;

  const LS_KEY = 'drafters:builder:v1';
  const PRESETS_KEY = 'drafters:builder:presets:v1';

  interface BuilderState {
    selected: string[];
    lang: string;
    title: string;
  }
  interface Preset {
    name: string;
    state: BuilderState;
    savedAt: number;
  }

  function loadPresets(): Preset[] {
    try {
      const raw = localStorage.getItem(PRESETS_KEY);
      if (!raw) return [];
      const arr = JSON.parse(raw);
      return Array.isArray(arr) ? arr : [];
    } catch {
      return [];
    }
  }
  function savePresets(list: Preset[]) {
    localStorage.setItem(PRESETS_KEY, JSON.stringify(list));
  }

  function pickTitle(t: any, lang: string): string {
    if (typeof t === 'string') return t;
    return t?.[lang] || t?.uk || t?.en || '';
  }

  function stripClauseBody(text: string): string {
    // Cut off editorial commentary heuristic (same as build-exports)
    const cutoff = text.search(
      /\n##\s+(На що звертати увагу|Things to watch|Notes|Practical|Практичні|Critical points|Why|Чому|When to use|Де використовується|Where used|When to|Де ще|Нотатки|Різниця|Difference|Що цей пункт НЕ|What this clause|Where else|Чому саме|How this works|How this clause|On watch)/i
    );
    if (cutoff !== -1) text = text.slice(0, cutoff);
    // Strip wiki links
    text = text.replace(/\[\[([^\]|]+)\|([^\]]+)\]\]/g, '$2');
    text = text.replace(/\[\[([^\]]+)\]\]/g, '$1');
    // Unescape
    text = text.replace(/\\([_*])/g, '$1');
    return text.trim();
  }

  function loadState(): { selected: string[]; lang: string; title: string } {
    try {
      const s = JSON.parse(localStorage.getItem(LS_KEY) || '{}');
      return {
        selected: Array.isArray(s.selected) ? s.selected : [],
        lang: s.lang || 'uk',
        title: s.title || 'Custom Contract',
      };
    } catch {
      return { selected: [], lang: 'uk', title: 'Custom Contract' };
    }
  }
  function saveState(state: { selected: string[]; lang: string; title: string }) {
    localStorage.setItem(LS_KEY, JSON.stringify(state));
  }

  // Encode/decode state in URL hash for shareable links
  function encodeHash(state: any): string {
    return btoa(unescape(encodeURIComponent(JSON.stringify(state))));
  }
  function decodeHash(hash: string): any {
    try {
      return JSON.parse(decodeURIComponent(escape(atob(hash))));
    } catch {
      return null;
    }
  }

  async function init() {
    const app = document.querySelector<HTMLElement>('[data-builder-app]');
    const loading = document.querySelector<HTMLElement>('[data-builder-loading]');
    if (!app) return;

    let manifest: Manifest = {};
    try {
      const resp = await fetch('/clauses.json');
      manifest = await resp.json();
    } catch (e) {
      if (loading) loading.textContent = 'Не вдалось завантажити бібліотеку пунктів';
      console.error(e);
      return;
    }

    loading?.setAttribute('hidden', '');
    app.removeAttribute('hidden');

    // State
    let state = loadState();
    // Override with hash state if present
    if (location.hash.startsWith('#s=')) {
      const h = decodeHash(location.hash.slice(3));
      if (h) state = { ...state, ...h };
    }

    const langSelect = app.querySelector<HTMLSelectElement>('[data-b-lang]')!;
    const titleInput = app.querySelector<HTMLInputElement>('[data-b-title]')!;
    const library = app.querySelector<HTMLElement>('[data-b-library]')!;
    const selectedList = app.querySelector<HTMLElement>('[data-b-selected]')!;
    const preview = app.querySelector<HTMLElement>('[data-b-preview]')!;
    const count = app.querySelector<HTMLElement>('[data-b-count]')!;
    const clearBtn = app.querySelector<HTMLButtonElement>('[data-b-clear]')!;
    const downloadBtn = app.querySelector<HTMLButtonElement>('[data-b-download-md]')!;
    const downloadHtmlBtn = app.querySelector<HTMLButtonElement>('[data-b-download-html]')!;
    const copyUrlBtn = app.querySelector<HTMLButtonElement>('[data-b-copy-url]')!;
    const searchInput = app.querySelector<HTMLInputElement>('[data-b-search]')!;
    const tagChips = app.querySelector<HTMLElement>('[data-b-tag-chips]')!;
    const grid = app.querySelector<HTMLElement>('[data-b-grid]')!;
    const saveBtn = app.querySelector<HTMLButtonElement>('[data-b-save]')!;
    const loadSelect = app.querySelector<HTMLSelectElement>('[data-b-load]')!;
    const deleteBtn = app.querySelector<HTMLButtonElement>('[data-b-delete]')!;
    const compareSelect = app.querySelector<HTMLSelectElement>('[data-b-compare]')!;
    const comparePane = app.querySelector<HTMLElement>('[data-b-compare-pane]')!;
    const compareBody = app.querySelector<HTMLElement>('[data-b-compare-body]')!;
    const compareLabel = app.querySelector<HTMLElement>('[data-b-compare-label]')!;
    const compareClose = app.querySelector<HTMLButtonElement>('[data-b-compare-close]')!;

    let activePresetName: string | null = null;
    let comparePresetName: string | null = null;

    langSelect.value = state.lang;
    titleInput.value = state.title;

    // Collect all unique tags
    const allTags = new Set<string>();
    for (const c of Object.values(manifest)) {
      for (const t of c.tags) allTags.add(t);
    }
    let activeTag = 'all';
    let searchQ = '';

    function renderTagChips() {
      const tags = ['all', ...Array.from(allTags).sort()];
      tagChips.innerHTML = tags
        .map(
          (t) =>
            `<button data-tag="${t}" class="${t === activeTag ? 'is-active' : ''}">${t}</button>`
        )
        .join('');
      tagChips.querySelectorAll<HTMLButtonElement>('button').forEach((b) => {
        b.addEventListener('click', () => {
          activeTag = b.dataset.tag!;
          renderTagChips();
          renderLibrary();
        });
      });
    }

    function renderLibrary() {
      const items = Object.entries(manifest)
        .filter(([, c]) => activeTag === 'all' || c.tags.includes(activeTag))
        .filter(([id, c]) => {
          if (!searchQ) return true;
          const t = pickTitle(c.title, state.lang).toLowerCase();
          return t.includes(searchQ.toLowerCase()) || id.includes(searchQ.toLowerCase());
        })
        .sort(([, a], [, b]) =>
          pickTitle(a.title, state.lang).localeCompare(pickTitle(b.title, state.lang))
        );
      library.innerHTML = items
        .map(
          ([id, c]) => `
          <li data-id="${id}" class="${state.selected.includes(id) ? 'is-selected' : ''}">
            <span>${pickTitle(c.title, state.lang)}</span>
            <span class="b-tags">${c.tags.slice(0, 2).join(' · ')}</span>
          </li>`
        )
        .join('');
      library.querySelectorAll<HTMLElement>('li').forEach((li) => {
        li.addEventListener('click', () => {
          const id = li.dataset.id!;
          if (state.selected.includes(id)) {
            state.selected = state.selected.filter((x) => x !== id);
          } else {
            state.selected.push(id);
          }
          persist();
          renderAll();
        });
      });
    }

    function renderSelected() {
      count.textContent = `Ваш контракт (${state.selected.length})`;
      if (state.selected.length === 0) {
        selectedList.innerHTML = '<li class="builder__empty">Клацніть пункт ліворуч, щоб додати</li>';
        return;
      }
      selectedList.innerHTML = state.selected
        .map((id, i) => {
          const c = manifest[id];
          const title = c ? pickTitle(c.title, state.lang) : id;
          return `
          <li data-id="${id}">
            <span>${title}</span>
            <span class="b-ctrls">
              <button data-up="${i}" ${i === 0 ? 'disabled' : ''}>↑</button>
              <button data-down="${i}" ${i === state.selected.length - 1 ? 'disabled' : ''}>↓</button>
              <button data-rem="${i}">×</button>
            </span>
          </li>`;
        })
        .join('');
      selectedList.querySelectorAll<HTMLButtonElement>('[data-up]').forEach((b) => {
        b.addEventListener('click', (e) => {
          e.stopPropagation();
          const i = parseInt(b.dataset.up!, 10);
          [state.selected[i - 1], state.selected[i]] = [state.selected[i], state.selected[i - 1]];
          persist();
          renderAll();
        });
      });
      selectedList.querySelectorAll<HTMLButtonElement>('[data-down]').forEach((b) => {
        b.addEventListener('click', (e) => {
          e.stopPropagation();
          const i = parseInt(b.dataset.down!, 10);
          [state.selected[i], state.selected[i + 1]] = [state.selected[i + 1], state.selected[i]];
          persist();
          renderAll();
        });
      });
      selectedList.querySelectorAll<HTMLButtonElement>('[data-rem]').forEach((b) => {
        b.addEventListener('click', (e) => {
          e.stopPropagation();
          const i = parseInt(b.dataset.rem!, 10);
          state.selected.splice(i, 1);
          persist();
          renderAll();
        });
      });
    }

    function buildMarkdown(): string {
      const parts: string[] = [];
      parts.push(`# ${state.title}\n`);
      parts.push('_Generated with the Drafters contract builder._\n');
      state.selected.forEach((id, i) => {
        const c = manifest[id];
        if (!c) return;
        const body = c.variants[state.lang] || c.variants.uk || c.variants.en || '';
        const title = pickTitle(c.title, state.lang);
        parts.push(`\n## ${i + 1}. ${title}\n`);
        parts.push(stripClauseBody(body) + '\n');
      });
      return parts.join('\n');
    }

    function renderPreview() {
      if (state.selected.length === 0) {
        preview.innerHTML = '<p class="builder__empty">Додайте хоча б один пункт для попереднього перегляду</p>';
        return;
      }
      const md = buildMarkdown();
      preview.innerHTML = mdToHtml(md);
    }

    function mdToHtml(md: string): string {
      // Minimal markdown → HTML for preview
      const esc = (s: string) => s.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]!));
      const lines = md.split('\n');
      const out: string[] = [];
      let inList = false;
      for (const l of lines) {
        if (l.startsWith('# ')) out.push(`<h1>${esc(l.slice(2))}</h1>`);
        else if (l.startsWith('## ')) out.push(`<h2>${esc(l.slice(3))}</h2>`);
        else if (l.startsWith('### ')) out.push(`<h3>${esc(l.slice(4))}</h3>`);
        else if (/^[-*]\s+/.test(l)) {
          if (!inList) { out.push('<ul>'); inList = true; }
          out.push(`<li>${inlineMd(esc(l.replace(/^[-*]\s+/, '')))}</li>`);
        } else {
          if (inList) { out.push('</ul>'); inList = false; }
          if (l.trim() === '') out.push('<br/>');
          else out.push(`<p>${inlineMd(esc(l))}</p>`);
        }
      }
      if (inList) out.push('</ul>');
      return out.join('');
    }
    function inlineMd(s: string): string {
      return s
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/_([^_]+)_/g, '<em>$1</em>')
        .replace(/`([^`]+)`/g, '<code>$1</code>');
    }

    function persist() {
      state.lang = langSelect.value;
      state.title = titleInput.value;
      saveState(state);
      location.hash = `#s=${encodeHash(state)}`;
    }

    function renderAll() {
      renderLibrary();
      renderSelected();
      renderPreview();
      renderCompare();
    }

    // --- Preset management ---
    function renderPresetSelectors() {
      const presets = loadPresets();
      const loadOptions = ['<option value="">— відкрити —</option>']
        .concat(
          presets.map(
            (p) =>
              `<option value="${p.name}" ${activePresetName === p.name ? 'selected' : ''}>${p.name} (${p.state.selected.length})</option>`
          )
        )
        .join('');
      loadSelect.innerHTML = loadOptions;

      const compareOptions = ['<option value="">— немає —</option>']
        .concat(
          presets.map(
            (p) =>
              `<option value="${p.name}" ${comparePresetName === p.name ? 'selected' : ''}>${p.name}</option>`
          )
        )
        .join('');
      compareSelect.innerHTML = compareOptions;

      deleteBtn.disabled = !activePresetName;
    }

    function buildMarkdownFrom(other: BuilderState): string {
      const parts: string[] = [];
      parts.push(`# ${other.title}\n`);
      parts.push('_Generated with the Drafters contract builder._\n');
      other.selected.forEach((id, i) => {
        const c = manifest[id];
        if (!c) return;
        const body = c.variants[other.lang] || c.variants.uk || c.variants.en || '';
        const title = pickTitle(c.title, other.lang);
        parts.push(`\n## ${i + 1}. ${title}\n`);
        parts.push(stripClauseBody(body) + '\n');
      });
      return parts.join('\n');
    }

    // Line-level diff for compare pane. Dumb but fair.
    function lineDiff(aText: string, bText: string): string {
      const aLines = aText.split('\n');
      const bLines = bText.split('\n');
      const aSet = new Set(aLines);
      const bSet = new Set(bLines);
      const out: string[] = [];
      const esc = (s: string) =>
        s.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]!));
      // Walk b to show both sides — additions relative to a, and show a's removals inline
      const seen = new Set<string>();
      for (const line of bLines) {
        if (seen.has(line)) {
          out.push(`<div class="diff-line diff-line--ctx">${esc(line) || '&nbsp;'}</div>`);
          continue;
        }
        seen.add(line);
        if (aSet.has(line)) {
          out.push(`<div class="diff-line diff-line--ctx">${esc(line) || '&nbsp;'}</div>`);
        } else {
          out.push(`<div class="diff-line diff-line--add">+ ${esc(line)}</div>`);
        }
      }
      // Append removals that were only in a
      const removed: string[] = [];
      for (const line of aLines) {
        if (!bSet.has(line) && !removed.includes(line)) {
          removed.push(line);
          out.push(`<div class="diff-line diff-line--del">− ${esc(line)}</div>`);
        }
      }
      return out.join('');
    }

    function renderCompare() {
      if (!comparePresetName) {
        comparePane.setAttribute('hidden', '');
        grid.classList.remove('builder__grid--compare');
        return;
      }
      const preset = loadPresets().find((p) => p.name === comparePresetName);
      if (!preset) {
        comparePresetName = null;
        comparePane.setAttribute('hidden', '');
        grid.classList.remove('builder__grid--compare');
        return;
      }
      comparePane.removeAttribute('hidden');
      grid.classList.add('builder__grid--compare');
      compareLabel.textContent = `Порівняння з «${preset.name}»`;

      const currentMd = buildMarkdown();
      const otherMd = buildMarkdownFrom(preset.state);
      compareBody.innerHTML = lineDiff(currentMd, otherMd);
    }

    function updatePreviewLabel() {
      const el = app.querySelector<HTMLElement>('[data-b-preview-label]');
      if (!el) return;
      el.textContent = activePresetName
        ? `Попередній перегляд · ${activePresetName}`
        : 'Попередній перегляд';
    }

    langSelect.addEventListener('change', () => { persist(); renderAll(); });
    titleInput.addEventListener('input', () => { persist(); renderPreview(); renderCompare(); });
    searchInput.addEventListener('input', () => { searchQ = searchInput.value; renderLibrary(); });
    clearBtn.addEventListener('click', () => {
      state.selected = [];
      activePresetName = null;
      updatePreviewLabel();
      persist();
      renderAll();
      renderPresetSelectors();
    });
    downloadBtn.addEventListener('click', () => {
      const md = buildMarkdown();
      const blob = new Blob([md], { type: 'text/markdown;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${(state.title || 'custom-contract').replace(/\s+/g, '-').toLowerCase()}.md`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });
    downloadHtmlBtn.addEventListener('click', () => {
      const md = buildMarkdown();
      const bodyHtml = mdToHtml(md);
      const titleSafe = (state.title || 'Custom Contract').replace(/[<>&]/g, '');
      const html = `<!doctype html>
<html lang="${state.lang}"><head><meta charset="utf-8" />
<title>${titleSafe}</title>
<style>
  body { font: 16px/1.55 Georgia, 'Times New Roman', serif; max-width: 720px; margin: 4rem auto; padding: 0 2rem; color: #1a1a1a; }
  h1 { font-size: 1.9rem; border-bottom: 2px solid #1a1a1a; padding-bottom: 0.3em; }
  h2 { font-size: 1.05rem; text-transform: uppercase; letter-spacing: 0.08em; font-family: 'Helvetica Neue', Arial, sans-serif; margin-top: 2.4em; padding-top: 0.9em; border-top: 1px solid #ccc; }
  h3 { font-size: 1rem; text-transform: uppercase; letter-spacing: 0.08em; font-family: 'Helvetica Neue', Arial, sans-serif; }
  p { margin: 0.8em 0; }
  ul, ol { padding-left: 1.4em; }
  table { width: 100%; border-collapse: collapse; margin: 1em 0; }
  th, td { border: 1px solid #ccc; padding: 0.4em 0.6em; text-align: left; }
  @media print { body { margin: 0; padding: 1.5cm 1.8cm; max-width: none; } }
</style>
</head><body>${bodyHtml}</body></html>`;
      const blob = new Blob([html], { type: 'text/html;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${(state.title || 'custom-contract').replace(/\s+/g, '-').toLowerCase()}.html`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });
    copyUrlBtn.addEventListener('click', async () => {
      persist();
      try {
        await navigator.clipboard.writeText(location.href);
        const orig = copyUrlBtn.textContent;
        copyUrlBtn.textContent = 'скопійовано ✓';
        setTimeout(() => { copyUrlBtn.textContent = orig; }, 1200);
      } catch {}
    });

    saveBtn.addEventListener('click', () => {
      const suggested = activePresetName || state.title || 'Новий шаблон';
      const name = prompt('Назва шаблону:', suggested);
      if (!name) return;
      const trimmed = name.trim();
      if (!trimmed) return;
      const presets = loadPresets();
      const existing = presets.findIndex((p) => p.name === trimmed);
      const snapshot: Preset = {
        name: trimmed,
        state: {
          selected: [...state.selected],
          lang: state.lang,
          title: state.title,
        },
        savedAt: Date.now(),
      };
      if (existing >= 0) {
        if (!confirm(`Шаблон «${trimmed}» вже існує. Перезаписати?`)) return;
        presets[existing] = snapshot;
      } else {
        presets.push(snapshot);
      }
      savePresets(presets);
      activePresetName = trimmed;
      updatePreviewLabel();
      renderPresetSelectors();
    });

    loadSelect.addEventListener('change', () => {
      const name = loadSelect.value;
      if (!name) {
        activePresetName = null;
        updatePreviewLabel();
        renderPresetSelectors();
        return;
      }
      const preset = loadPresets().find((p) => p.name === name);
      if (!preset) return;
      state = {
        selected: [...preset.state.selected],
        lang: preset.state.lang,
        title: preset.state.title,
      };
      activePresetName = name;
      langSelect.value = state.lang;
      titleInput.value = state.title;
      updatePreviewLabel();
      persist();
      renderAll();
      renderPresetSelectors();
    });

    deleteBtn.addEventListener('click', () => {
      if (!activePresetName) return;
      if (!confirm(`Видалити шаблон «${activePresetName}»?`)) return;
      const presets = loadPresets().filter((p) => p.name !== activePresetName);
      savePresets(presets);
      if (comparePresetName === activePresetName) {
        comparePresetName = null;
      }
      activePresetName = null;
      updatePreviewLabel();
      renderPresetSelectors();
      renderCompare();
    });

    compareSelect.addEventListener('change', () => {
      comparePresetName = compareSelect.value || null;
      renderCompare();
    });

    compareClose.addEventListener('click', () => {
      comparePresetName = null;
      compareSelect.value = '';
      renderCompare();
    });

    renderTagChips();
    renderPresetSelectors();
    updatePreviewLabel();
    renderAll();
  }

  init();
  document.addEventListener('astro:page-load', () => init());
</script>
