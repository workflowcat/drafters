---
/**
 * FileHistory — renders git history for a content file as a
 * collapsible section. Lists commits, and for each pair of
 * consecutive revisions offers an inline diff view.
 *
 * Used on clause pages (under the clause body) and document
 * pages (under the body text). Runs at build time.
 */
import {
  fileCommits,
  fileDiff,
  touchedSinceDate,
  contentPath,
  type FileCommit,
  type FileDiff,
} from '~/lib/file-history';

interface Props {
  collection: string;
  id: string;             // e.g. 'payment-dispute.uk' or 'services-agreement-sloboda-2026'
  reviewedOn?: string;    // ISO date, used to tag "since last review"
}

const { collection, id, reviewedOn } = Astro.props as Props;
const path = contentPath(collection, id);

const commits: FileCommit[] = fileCommits(path, 12);

// Precompute the diff between each pair of consecutive commits.
// diffs[i] is the diff introduced by commits[i] (i.e. from commits[i+1] to commits[i]).
const diffs: Array<FileDiff | null> = [];
for (let i = 0; i < commits.length; i++) {
  const newer = commits[i];
  const older = commits[i + 1];
  if (!older) {
    diffs.push(null);
    continue;
  }
  diffs.push(fileDiff(path, older.hash, newer.hash));
}

// Commits since last review — separate list, to highlight pending.
const sinceReview: FileCommit[] = reviewedOn
  ? touchedSinceDate(path, reviewedOn)
  : [];

const hasHistory = commits.length > 0;
const hasPendingReview = sinceReview.length > 0;

// Pre-render each diff as HTML so the template doesn't need to
// nest JSX inside <pre>, which confuses Astro's parser.
function escHtml(s: string): string {
  return s.replace(/[&<>]/g, (c) => (
    c === '&' ? '&amp;' : c === '<' ? '&lt;' : '&gt;'
  ));
}
function renderDiffHtml(d: FileDiff): string {
  const out: string[] = [];
  for (const h of d.hunks) {
    out.push(`<span class="file-history__hunk-head">${escHtml(h.header)}\n</span>`);
    for (const l of h.lines) {
      const prefix = l.kind === 'add' ? '+' : l.kind === 'del' ? '−' : ' ';
      out.push(
        `<span class="file-history__line file-history__line--${l.kind}">${prefix}${escHtml(l.text)}\n</span>`
      );
    }
  }
  return out.join('');
}
const diffHtml: Array<string | null> = diffs.map((d) =>
  d && d.hunks.length > 0 ? renderDiffHtml(d) : null
);
---

{hasHistory && (
  <section class="file-history">
    <details class="file-history__shell">
      <summary class="file-history__summary">
        <span class="file-history__label">Історія змін</span>
        <span class="file-history__count">{commits.length} ком.</span>
        {hasPendingReview && (
          <span class="file-history__pending" title={`${sinceReview.length} commits since ${reviewedOn}`}>
            {sinceReview.length} після ревʼю
          </span>
        )}
      </summary>

      <ol class="file-history__list">
        {commits.map((c, i) => {
          const diff = diffs[i];
          const isSinceReview = reviewedOn && c.date >= reviewedOn;
          return (
            <li class:list={["file-history__item", isSinceReview && "file-history__item--pending"]}>
              <header class="file-history__row">
                <code class="file-history__hash">{c.shortHash}</code>
                <span class="file-history__date">{c.date}</span>
                <span class="file-history__subject">{c.subject}</span>
                <span class="file-history__author">{c.author}</span>
                {diff && (diff.added > 0 || diff.removed > 0) && (
                  <span class="file-history__stat">
                    <span class="file-history__stat-add">+{diff.added}</span>{' '}
                    <span class="file-history__stat-del">−{diff.removed}</span>
                  </span>
                )}
              </header>

              {diffHtml[i] && (
                <details class="file-history__diff-shell">
                  <summary class="file-history__diff-summary">показати diff</summary>
                  <pre class="file-history__diff" set:html={diffHtml[i]} />
                </details>
              )}
            </li>
          );
        })}
      </ol>
    </details>
  </section>
)}

<style>
  .file-history {
    margin: 3rem 0 2rem;
    max-width: var(--measure);
  }
  .file-history__shell {
    border: 1px solid var(--rule);
    background: var(--paper-soft);
  }
  .file-history__summary {
    cursor: pointer;
    padding: 0.8rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-family: var(--font-sans);
    font-size: var(--fs-meta);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink);
  }
  .file-history__summary::-webkit-details-marker { display: none; }
  .file-history__summary::marker { content: ''; }
  .file-history__label { font-weight: var(--fw-bold); }
  .file-history__count { color: var(--ink-faint); }
  .file-history__pending {
    margin-left: auto;
    padding: 0.1em 0.5em;
    background: var(--peach);
    color: var(--ink);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-label);
  }
  .file-history__list {
    list-style: none;
    padding: 0 1rem 1rem;
    margin: 0;
  }
  .file-history__item {
    padding: 0.6rem 0;
    border-top: 1px dashed var(--rule);
  }
  .file-history__item--pending {
    background: color-mix(in srgb, var(--peach) 18%, transparent);
    margin: 0 -1rem;
    padding: 0.6rem 1rem;
    border-top: 1px dashed var(--peach-dim, var(--rule));
  }
  .file-history__row {
    display: grid;
    grid-template-columns: auto auto 1fr auto auto;
    gap: 0.7rem;
    align-items: baseline;
    font-family: var(--font-serif);
    font-size: var(--fs-small);
  }
  .file-history__hash {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: var(--fs-meta);
    color: var(--ink-faint);
  }
  .file-history__date {
    font-family: var(--font-sans);
    font-size: var(--fs-meta);
    color: var(--ink-muted);
  }
  .file-history__subject {
    color: var(--ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }
  .file-history__author {
    font-family: var(--font-sans);
    font-size: var(--fs-meta);
    color: var(--ink-faint);
  }
  .file-history__stat {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: var(--fs-meta);
    white-space: nowrap;
  }
  .file-history__stat-add { color: #2d6a2d; }
  .file-history__stat-del { color: #8a2a2a; }

  .file-history__diff-shell {
    margin-top: 0.5rem;
  }
  .file-history__diff-summary {
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: var(--fs-meta);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-faint);
    padding-left: 0.2rem;
  }
  .file-history__diff-summary:hover { color: var(--ink); }
  .file-history__diff {
    margin: 0.5rem 0 0;
    padding: 0.8rem 1rem;
    background: var(--paper);
    border: 1px solid var(--rule);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: calc(var(--fs-meta) * 1.04);
    line-height: 1.5;
    white-space: pre;
    overflow-x: auto;
    max-height: 28rem;
  }
  .file-history__hunk-head {
    color: var(--ink-faint);
    font-weight: var(--fw-bold);
  }
  .file-history__line--add {
    background: color-mix(in srgb, #7cb07c 22%, transparent);
    color: #1f4a1f;
    display: inline-block;
    width: 100%;
  }
  .file-history__line--del {
    background: color-mix(in srgb, #c88080 22%, transparent);
    color: #5a1f1f;
    display: inline-block;
    width: 100%;
  }
  .file-history__line--ctx {
    color: var(--ink-muted);
  }
</style>
