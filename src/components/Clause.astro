---
/**
 * Inline a clause by baseId, in a requested language.
 *
 * Usage (inside MDX):
 *   <Clause baseId="payment-dispute" lang="uk" />
 *
 * If the requested language isn't present, falls back to the first
 * available variant and shows a small "[fallback]" indicator.
 */
import { render } from 'astro:content';
import { getClauseByBase } from '~/lib/clause-variants';

export interface Props {
  baseId: string;
  lang?: 'uk' | 'en' | 'de';
  showCommentary?: boolean;
}

const { baseId, lang = 'uk', showCommentary = false } = Astro.props;
const { entry, lang: resolvedLang, fallback } = await getClauseByBase(baseId, lang);

if (!entry) {
  throw new Error(`<Clause>: no variant found for baseId "${baseId}"`);
}

const title =
  typeof entry.data.title === 'string'
    ? entry.data.title
    : (entry.data.title as any)[resolvedLang ?? lang] ??
      (entry.data.title as any).uk ??
      baseId;

const { Content } = await render(entry);
---
<section class="clause" data-clause-base={baseId} data-lang={resolvedLang}>
  <header class="clause__header">
    clause / {baseId}
    {fallback && (
      <span class="clause__lang-fallback">[fallback: {resolvedLang}]</span>
    )}
  </header>
  <h3>{title}</h3>
  <Content />
  {showCommentary && entry.data.commentary && (
    <aside class="clause__commentary">
      <strong>Коментар.</strong> {entry.data.commentary}
    </aside>
  )}
</section>
