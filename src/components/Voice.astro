---
/**
 * Disco Elysium-style margin voice. A compact card styled per
 * voice personality. Positioning (float / inline) is controlled
 * by the host context — e.g. the contract page floats these
 * into a dedicated right column. On pages that don't style .voice,
 * it falls back to an inline card.
 *
 * Voices:
 *   legal        ⚖️  Юридичний   steel blue
 *   business     💼  Бізнес       muted green
 *   negotiations 🎯  Переговори   lavender
 *   delivery     🔧  Delivery     warm amber
 *   interaction  🔗  Взаємодія    neutral grey
 */
export interface Props {
  voice: 'legal' | 'business' | 'negotiations' | 'delivery' | 'interaction';
}

const { voice } = Astro.props;

const config = {
  legal:        { emoji: '⚖️', label: 'Юридичний',  color: '#7e8fa6' },
  business:     { emoji: '💼', label: 'Бізнес',      color: '#6b9e6b' },
  negotiations: { emoji: '🎯', label: 'Переговори',  color: '#9ca9ef' },
  delivery:     { emoji: '🔧', label: 'Delivery',    color: '#c4956a' },
  interaction:  { emoji: '🔗', label: 'Взаємодія',   color: '#a0a0a0' },
} as const;

const v = config[voice];
---

<aside
  class={`voice voice--${voice}`}
  style={`--voice-color: ${v.color}`}
  data-voice={voice}
>
  <p class="voice__label">
    <span class="voice__emoji" aria-hidden="true">{v.emoji}</span>
    <span class="voice__name">{v.label}</span>
  </p>
  <div class="voice__body">
    <slot />
  </div>
</aside>

<style>
  .voice {
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    line-height: 1.55;
    color: var(--ink-muted);
    margin: 1rem 0;
    padding: 0.7rem 0.9rem;
    background: var(--paper-soft);
    border-left: 3px solid var(--voice-color);
    max-width: 100%;
  }

  .voice__label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: var(--fw-bold);
    color: var(--voice-color);
    margin: 0 0 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    letter-spacing: 0.02em;
  }

  .voice__emoji {
    font-size: 0.85rem;
    line-height: 1;
  }

  .voice__name {
    line-height: 1;
  }

  .voice__body :global(p) {
    margin: 0.3rem 0;
  }

  .voice__body :global(p:first-child) {
    margin-top: 0;
  }

  .voice__body :global(p:last-child) {
    margin-bottom: 0;
  }

  .voice__body :global(a) {
    color: var(--voice-color);
  }

  .voice__body :global(code) {
    font-size: 0.85em;
    background: color-mix(in srgb, var(--voice-color) 10%, transparent);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
</style>
