---
/**
 * Tufte-style sidenote / margin voice. A compact, subdued comment
 * anchored to a colored left border. Positioning (float / inline) is
 * controlled by the host context — the contract page floats these
 * into a dedicated right column on wide screens; elsewhere they fall
 * back to an inline bordered block.
 *
 * The persona label is bilingual; CSS picks one based on the closest
 * <html lang> via :lang(). One source of truth for which language is
 * shown — the page sets <html lang>, voices follow.
 *
 * Voices (color only — no emoji, no chip):
 *   legal        Legal / Юридичний       steel blue
 *   business     Business / Бізнес       muted green
 *   negotiations Negotiations / Переговори  lavender
 *   delivery     Delivery / Delivery     warm amber
 *   interaction  Interaction / Взаємодія neutral grey
 */
export interface Props {
  voice: 'legal' | 'business' | 'negotiations' | 'delivery' | 'interaction';
}

const { voice } = Astro.props;

const config = {
  legal:        { en: 'Legal',        uk: 'Юридичний',  color: '#7e8fa6' },
  business:     { en: 'Business',     uk: 'Бізнес',      color: '#6b9e6b' },
  negotiations: { en: 'Negotiations', uk: 'Переговори',  color: '#9ca9ef' },
  delivery:     { en: 'Delivery',     uk: 'Delivery',    color: '#c4956a' },
  interaction:  { en: 'Interaction',  uk: 'Взаємодія',   color: '#a0a0a0' },
} as const;

const v = config[voice];
---

<aside
  class={`voice voice--${voice}`}
  style={`--voice-color: ${v.color}`}
  data-voice={voice}
>
  <p class="voice__label">
    <span lang="en" class="voice__label-en">{v.en}</span>
    <span lang="uk" class="voice__label-uk">{v.uk}</span>
  </p>
  <div class="voice__body">
    <slot />
  </div>
</aside>

<style>
  .voice {
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    line-height: 1.55;
    color: var(--ink-muted);
    margin: 1rem 0;
    padding: 0 0 0 0.9rem;
    border-left: 2px solid var(--voice-color);
    max-width: 100%;
  }

  .voice__label {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--voice-color);
    margin: 0 0 0.3rem;
    opacity: 0.85;
  }

  /* Bilingual label switch via :lang() on the page root.
     Page lang="en" → English label visible, Ukrainian hidden. */
  :global(html[lang="en"]) .voice__label-uk,
  :global(html:not([lang])) .voice__label-uk { display: none; }
  :global(html[lang="uk"]) .voice__label-en,
  :global(html[lang="de"]) .voice__label-en { display: none; }
  :global(html[lang="uk"]) .voice__label-uk,
  :global(html[lang="en"]) .voice__label-en { display: inline; }

  .voice__body :global(p) {
    margin: 0.35rem 0;
  }

  .voice__body :global(p:first-child) {
    margin-top: 0;
  }

  .voice__body :global(p:last-child) {
    margin-bottom: 0;
  }

  .voice__body :global(a) {
    color: var(--voice-color);
  }

  .voice__body :global(code) {
    font-size: 0.85em;
    background: color-mix(in srgb, var(--voice-color) 10%, transparent);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
</style>
