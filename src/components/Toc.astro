---
/**
 * On-this-page table of contents, scroll-spied.
 *
 * Takes an array of {depth, slug, text} headings parsed at build time
 * from the entry's MDX. Renders into the right margin on desktop,
 * collapses above the content on mobile.
 */
export interface Heading {
  depth: number;
  slug: string;
  text: string;
}
export interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
// Only h2 / h3 in TOC
const visible = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{visible.length > 1 && (
  <nav class="toc" aria-label="На цій сторінці">
    <p class="toc__label">На цій сторінці</p>
    <ol>
      {visible.map((h) => (
        <li class={`toc__item toc__item--d${h.depth}`}>
          <a href={`#${h.slug}`} data-toc-link>{h.text}</a>
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  .toc {
    font-family: var(--font-sans);
    font-size: var(--fs-meta);
    color: var(--ink-muted);
    max-width: 20rem;
  }
  .toc__label {
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-faint);
    margin: 0 0 0.6rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--rule);
  }
  .toc ol {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc__item {
    padding: 0.25rem 0;
    border-left: 2px solid transparent;
    padding-left: 0.6rem;
    transition: border-color var(--t-base);
  }
  .toc__item--d3 {
    padding-left: 1.4rem;
    font-size: calc(var(--fs-meta) * 0.95);
  }
  .toc__item a {
    color: var(--ink-muted);
    text-decoration: none;
    transition: color var(--t-base);
    line-height: 1.4;
    display: block;
  }
  .toc__item a:hover {
    color: var(--lavender-dim);
  }
  .toc__item.is-active {
    border-left-color: var(--lavender);
  }
  .toc__item.is-active > a {
    color: var(--ink);
  }
  @media (max-width: 1023px) {
    .toc {
      margin: 1.6rem 0 2rem;
      padding: 1rem 1.2rem;
      background: var(--paper-soft);
      border-left: 2px solid var(--lavender);
      max-width: var(--measure);
    }
  }
</style>

<script>
  function setupToc() {
    const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
    if (links.length === 0) return;
    const byId = new Map<string, HTMLElement>();
    links.forEach((a) => {
      const id = a.getAttribute('href')?.slice(1);
      if (id) byId.set(id, a.closest('.toc__item') as HTMLElement);
    });
    const headings = Array.from(byId.keys())
      .map((id) => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];
    if (headings.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            byId.forEach((el, key) => el.classList.toggle('is-active', key === id));
          }
        });
      },
      { rootMargin: '-20% 0% -70% 0%' }
    );
    headings.forEach((h) => observer.observe(h));
  }
  setupToc();
  document.addEventListener('astro:page-load', setupToc);
</script>
