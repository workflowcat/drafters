---
/**
 * Export menu. Links to static files pre-generated at build time
 * by scripts/export/build-exports.mjs.
 *
 * Usage:
 *   <ExportMenu workflowId="..." />
 *   <ExportMenu documentId="..." />
 *   <ExportMenu clauseId="..." />
 */
export interface Props {
  workflowId?: string;
  documentId?: string;
  clauseId?: string;
}
const { workflowId, documentId, clauseId } = Astro.props;

type Link = { label: string; href: string; group?: string };
const links: Link[] = [];

if (workflowId) {
  links.push({ label: '.mdx (raw)', href: `/exports/workflows/${workflowId}/source.mdx`, group: 'source' });
  links.push({ label: '.docx', href: `/exports/workflows/${workflowId}/workflow.docx`, group: 'document' });
  links.push({ label: '.zip (bundle)', href: `/exports/workflows/${workflowId}/bundle.zip`, group: 'bundle' });
}
if (documentId) {
  links.push({ label: '.mdx (raw)', href: `/exports/documents/${documentId}/source.mdx`, group: 'source' });
  links.push({ label: '.docx', href: `/exports/documents/${documentId}/document.docx`, group: 'document' });
  links.push({ label: '.zip (з контекстом)', href: `/exports/documents/${documentId}/with-context.zip`, group: 'bundle' });
}
if (clauseId) {
  links.push({ label: '.mdx (raw)', href: `/exports/clauses/${clauseId}/source.mdx`, group: 'source' });
  links.push({ label: '.docx', href: `/exports/clauses/${clauseId}/clause.docx`, group: 'document' });
}
---

<div class="header__actions">
  <span class="pill">експорт</span>
  {links.map((l) => (
    <a class="btn btn--ghost" href={l.href} download>{l.label}</a>
  ))}
</div>
