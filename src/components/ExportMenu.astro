---
/**
 * Placeholder export menu. Phase 1 ships with a raw .mdx link only;
 * docx/pdf/zip builders land in Phase 2.
 */
export interface Props {
  rawHref?: string;
}
const { rawHref } = Astro.props;
---
<div class="header__actions">
  {rawHref && (
    <a class="btn btn--ghost" href={rawHref} download>
      Експорт .mdx
    </a>
  )}
  <span class="pill">docx / pdf / zip — phase 2</span>
</div>
