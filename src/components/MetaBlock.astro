---
/**
 * Metadata strip below page titles. Minimal — just the updated date
 * when present. No pills, no uppercase chrome, no pillar tags.
 */
export interface Props {
  pillar?: string;
  languages?: string[];
  status?: string;
  updated?: string;
}

const { updated } = Astro.props;
---
{updated && (
  <div class="header__meta">
    <span class="header__meta-item">Updated {updated}</span>
  </div>
)}
