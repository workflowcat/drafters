---
/**
 * Client-side reading utilities, all hydrated in the page.
 *
 *   f            — toggle focus mode (hides rail + margin + backlinks)
 *   shift+c      — copy page body as markdown
 *
 * The component renders a small floating toolbar that surfaces these
 * actions with visible buttons + kbd hints. The toolbar fades out
 * in focus mode (hover to see it again).
 */
---

<div class="reading-tools" data-reading-tools>
  <button class="reading-tools__btn" data-rt-focus title="Режим читання">
    <span>focus</span>
    <kbd>f</kbd>
  </button>
  <button class="reading-tools__btn" data-rt-copy title="Копіювати як markdown">
    <span>copy .md</span>
    <kbd>C</kbd>
  </button>
</div>

<style is:global>
  .reading-tools {
    position: fixed;
    right: 1.5rem;
    bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    z-index: 90;
    background: var(--paper);
    border: 1px solid var(--rule);
    padding: 0.4rem;
    box-shadow: 4px 4px 0 0 var(--lavender-wash);
  }
  .reading-tools__btn {
    display: flex;
    align-items: center;
    gap: 0.5em;
    background: transparent;
    border: 0;
    padding: 0.35rem 0.6rem;
    font-family: var(--font-sans);
    font-size: var(--fs-meta);
    font-weight: var(--fw-bold);
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    cursor: pointer;
    transition: color var(--t-base), background var(--t-base);
    justify-content: space-between;
    min-width: 6.5rem;
  }
  .reading-tools__btn:hover {
    color: var(--ink);
    background: var(--lavender-wash);
  }
  .reading-tools__btn.is-active {
    color: var(--ink);
    background: var(--lavender);
  }
  .reading-tools__btn kbd {
    margin-left: 0;
  }

  body.is-focus-mode .page__rail,
  body.is-focus-mode .page__margin,
  body.is-focus-mode .header__crumb,
  body.is-focus-mode .header__meta,
  body.is-focus-mode .header__actions,
  body.is-focus-mode .backlinks,
  body.is-focus-mode .related,
  body.is-focus-mode .page-footer,
  body.is-focus-mode .mobile-nav,
  body.is-focus-mode .scroll-progress {
    display: none !important;
  }
  body.is-focus-mode .page {
    grid-template-columns: minmax(0, var(--measure)) !important;
    max-width: var(--measure) !important;
    padding-top: 5rem !important;
  }
  body.is-focus-mode .page__body {
    font-size: calc(var(--fs-body) * 1.08);
    line-height: 1.75;
  }
  body.is-focus-mode .reading-tools {
    opacity: 0.3;
    transition: opacity var(--t-base);
  }
  body.is-focus-mode .reading-tools:hover {
    opacity: 1;
  }
</style>

<script>
  function setupReadingTools() {
    const focusBtn = document.querySelector<HTMLButtonElement>('[data-rt-focus]');
    const copyBtn = document.querySelector<HTMLButtonElement>('[data-rt-copy]');
    if (!focusBtn) return;

    // ── Focus mode ────────────────────────────────
    const wasFocus = localStorage.getItem('drafters:focus') === '1';
    if (wasFocus) {
      document.body.classList.add('is-focus-mode');
      focusBtn.classList.add('is-active');
    }
    focusBtn.addEventListener('click', toggleFocus);
    function toggleFocus() {
      const now = document.body.classList.toggle('is-focus-mode');
      focusBtn?.classList.toggle('is-active', now);
      localStorage.setItem('drafters:focus', now ? '1' : '0');
    }

    // ── Copy as markdown ──────────────────────────
    copyBtn?.addEventListener('click', copyMarkdown);
    async function copyMarkdown() {
      const article = document.querySelector('article');
      if (!article) return;
      const md = htmlToMarkdown(article);
      try {
        await navigator.clipboard.writeText(md);
        flashButton(copyBtn!, 'скопійовано ✓');
      } catch {
        flashButton(copyBtn!, 'помилка');
      }
    }

    function htmlToMarkdown(el: HTMLElement): string {
      const clone = el.cloneNode(true) as HTMLElement;
      clone.querySelectorAll('.reading-tools, .scroll-progress, .page__rail, .page__margin, .backlinks, .related, .page-footer, button').forEach((e) => e.remove());
      const walk = (node: Node): string => {
        if (node.nodeType === Node.TEXT_NODE) return node.textContent || '';
        if (node.nodeType !== Node.ELEMENT_NODE) return '';
        const e = node as HTMLElement;
        const tag = e.tagName.toLowerCase();
        const kids = Array.from(e.childNodes).map(walk).join('');
        switch (tag) {
          case 'h1': return `# ${kids}\n\n`;
          case 'h2': return `## ${kids}\n\n`;
          case 'h3': return `### ${kids}\n\n`;
          case 'h4': return `#### ${kids}\n\n`;
          case 'p': return `${kids}\n\n`;
          case 'strong': case 'b': return `**${kids}**`;
          case 'em': case 'i': return `_${kids}_`;
          case 'li': return `- ${kids}\n`;
          case 'ul': case 'ol': return `${kids}\n`;
          case 'code': return `\`${kids}\``;
          case 'br': return '\n';
          case 'a':
            const href = (e as HTMLAnchorElement).href;
            return href ? `[${kids}](${href})` : kids;
          default: return kids;
        }
      };
      return walk(clone).replace(/\n{3,}/g, '\n\n').trim();
    }

    function flashButton(btn: HTMLElement, text: string) {
      const orig = btn.querySelector('span')?.textContent;
      const span = btn.querySelector('span');
      if (!span) return;
      span.textContent = text;
      setTimeout(() => { if (orig) span.textContent = orig; }, 1400);
    }

    // ── Keyboard bindings ─────────────────────────
    document.addEventListener('keydown', (e) => {
      if (['INPUT', 'TEXTAREA'].includes((e.target as HTMLElement)?.tagName)) return;
      if ((e.target as HTMLElement)?.isContentEditable) return;
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      if (e.key === 'f') { e.preventDefault(); toggleFocus(); }
      else if (e.key === 'C') { e.preventDefault(); copyMarkdown(); }
    });
  }

  setupReadingTools();
  document.addEventListener('astro:page-load', setupReadingTools);
</script>
