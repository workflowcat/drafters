---
/**
 * Base layout for every content page.
 */
import '~/styles/base.css';
import '~/styles/layout.css';
import '~/styles/print.css';
import { ClientRouter } from 'astro:transitions';
import MobileNav from '~/components/MobileNav.astro';
import CommandPalette from '~/components/CommandPalette.astro';

export interface Props {
  title: string;
  description?: string;
  crumbSegments: string[];
  lang?: 'uk' | 'en';
}

const { title, description, crumbSegments, lang = 'uk' } = Astro.props;
const pageTitle = crumbSegments.length === 0 ? 'Drafters' : `${title} · Drafters`;

const crumbs = crumbSegments.map((seg, i) => ({
  label: seg,
  href: `/${crumbSegments.slice(0, i + 1).join('/')}`,
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description ?? 'Drafters — бібліотека контрактів для ІТ-сервісних компаній.'} />
    <meta name="color-scheme" content="light" />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <ClientRouter />
  </head>
  <body>
    <MobileNav />
    <CommandPalette />

    <div class="page">
      <aside class="page__rail" aria-label="Навігація">
        <slot name="rail">
          <div class="page__rail-inner">
            <button class="page__rail-search" data-open-palette aria-label="Пошук">
              <span>Пошук</span>
              <kbd>/</kbd>
            </button>
            <nav class="page__rail-nav">
              <a href="/">Головна</a>
              <a href="/contracts">Контракти</a>
              <a href="/clauses">Пункти</a>
              <a href="/cases">Кейси</a>
              <a href="/cast">Персонажі</a>
            </nav>
          </div>
        </slot>
      </aside>

      <main class="page__body">
        <header class="header">
          {crumbs.length > 0 && (
            <nav class="header__crumb" aria-label="Breadcrumb">
              <a href="/">Drafters</a>
              {crumbs.map((c) => (
                <>
                  <span aria-hidden="true">/</span>
                  <a href={c.href}>{c.label}</a>
                </>
              ))}
            </nav>
          )}
          <slot name="header" />
        </header>

        <article>
          <slot />
        </article>
      </main>

      <aside class="page__margin" aria-label="Нотатки">
        <slot name="margin" />
      </aside>
    </div>

    <style is:global>
      .page__rail-inner {
        position: sticky;
        top: 3rem;
        display: flex;
        flex-direction: column;
        gap: 1.4rem;
        min-width: 0;
      }
      .page__rail-search {
        font-family: var(--font-sans);
        font-size: var(--fs-meta);
        font-weight: var(--fw-bold);
        background: transparent;
        color: var(--ink-muted);
        border: 1px solid var(--rule);
        padding: 0.55rem 0.8rem;
        cursor: pointer;
        width: 100%;
        text-align: left;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: background var(--t-base), color var(--t-base), border-color var(--t-base);
      }
      .page__rail-search:hover {
        color: var(--ink);
        border-color: var(--ink);
        background: var(--lavender-wash);
      }
    </style>
  </body>
</html>
