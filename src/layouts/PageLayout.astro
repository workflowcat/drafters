---
/**
 * Base layout for every content page.
 *
 * Props:
 *   title         — string shown in <title> and (optionally) as h1
 *   description   — meta description
 *   crumbSegments — breadcrumb trail, e.g. ["workflows", "subcontractor-onboarding"]
 */
import '~/styles/base.css';
import '~/styles/layout.css';
import '~/styles/print.css';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
  crumbSegments: string[];
  lang?: 'uk' | 'en' | 'de';
}

const { title, description, crumbSegments, lang = 'uk' } = Astro.props;
const pageTitle = crumbSegments.length === 0 ? 'Drafters' : `${title} · Drafters`;

// Build breadcrumb with cumulative paths
const crumbs = crumbSegments.map((seg, i) => ({
  label: seg,
  href: `/${crumbSegments.slice(0, i + 1).join('/')}`,
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description ?? 'Drafters — робоча вікі для ІТ-сервісних компаній.'} />
    <meta name="color-scheme" content="light" />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <ClientRouter />
  </head>
  <body>
    <div class="page">
      <aside class="page__rail" aria-label="Навігація">
        <slot name="rail">
          <nav>
            <a href="/">Головна</a>
            <a href="/workflows">Процеси</a>
            <a href="/documents">Документи</a>
            <a href="/clauses">Пункти</a>
            <a href="/terms">Терміни</a>
            <a href="/roles">Ролі</a>
          </nav>
        </slot>
      </aside>

      <main class="page__body">
        <header class="header">
          {crumbs.length > 0 && (
            <nav class="header__crumb" aria-label="Breadcrumb">
              <a href="/">Drafters</a>
              {crumbs.map((c) => (
                <>
                  <span aria-hidden="true">/</span>
                  <a href={c.href}>{c.label}</a>
                </>
              ))}
            </nav>
          )}
          <slot name="header" />
        </header>

        <article>
          <slot />
        </article>
      </main>

      <aside class="page__margin" aria-label="Нотатки">
        <slot name="margin" />
      </aside>
    </div>

    <script>
      // Hydrate wikilink tooltips. Pure DOM, no framework.
      function setupTooltips() {
        const links = document.querySelectorAll<HTMLAnchorElement>('.wikilink:not(.wikilink--broken)');
        let popover: HTMLDivElement | null = document.querySelector('.wikilink-popover');

        function show(link: HTMLAnchorElement) {
          const short = link.dataset.wikiShort;
          const type = link.dataset.wikiType;
          if (!short && !type) return;
          if (!popover) {
            popover = document.createElement('div');
            popover.className = 'wikilink-popover';
            popover.setAttribute('role', 'tooltip');
            document.body.appendChild(popover);
          }
          const parts: string[] = [];
          if (type) parts.push(`<span class="wp-type">${type}</span>`);
          if (short) parts.push(`<span class="wp-short">${short}</span>`);
          popover.innerHTML = parts.join('');
          popover.style.display = 'block';
          requestAnimationFrame(() => {
            if (popover) popover.style.opacity = '1';
          });
          const rect = link.getBoundingClientRect();
          popover.style.left = `${rect.left + window.scrollX}px`;
          popover.style.top = `${rect.bottom + window.scrollY + 8}px`;
        }

        function hide() {
          if (popover) {
            popover.style.opacity = '0';
            setTimeout(() => {
              if (popover && popover.style.opacity === '0') popover.style.display = 'none';
            }, 180);
          }
        }

        for (const link of links) {
          link.addEventListener('mouseenter', () => show(link));
          link.addEventListener('focus', () => show(link));
          link.addEventListener('mouseleave', hide);
          link.addEventListener('blur', hide);
        }
      }

      setupTooltips();
      document.addEventListener('astro:page-load', setupTooltips);
    </script>
    <style is:global>
      .wikilink-popover {
        position: absolute;
        display: none;
        opacity: 0;
        max-width: 26rem;
        padding: 0.9rem 1.1rem;
        background: var(--paper);
        border: 1px solid var(--ink);
        border-radius: 0;
        font-family: var(--font-serif);
        font-size: var(--fs-small);
        line-height: 1.5;
        color: var(--ink);
        box-shadow: 6px 6px 0 0 var(--lavender);
        z-index: 100;
        pointer-events: none;
        transition: opacity var(--t-base);
      }
      .wikilink-popover .wp-type {
        display: block;
        font-family: var(--font-sans);
        font-weight: var(--fw-bold);
        font-size: var(--fs-meta);
        color: var(--ink-faint);
        margin-bottom: 0.4rem;
        text-transform: uppercase;
        letter-spacing: var(--tracking-label);
      }
      .wikilink-popover .wp-short {
        font-style: italic;
        color: var(--ink-muted);
      }
    </style>
  </body>
</html>
